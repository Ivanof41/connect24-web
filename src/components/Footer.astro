---
interface Props {
  t: {
    tagline: string;
    col1_title: string;
    col2_title: string;
    col3_title: string;
    como: string;
    acceder: string;
    go: string;
    sol1: string;
    sol2: string;
    sol3: string;
    sol5: string;
    sol6: string;
    sol7: string;
    emp1: string;
    emp2: string;
    emp3: string;
    emp4: string;
    copy: string;
  };
}
const { t } = Astro.props;
---

<footer class="footer">
  <div class="container footer-inner">

    <!-- Brand -->
    <div class="footer-brand">
      <img
        src="/logo.png"
        alt="Connect24"
        class="footer-logo"
      />
      <p class="footer-tagline">{t.tagline}</p>
      <div class="footer-badges">
        <span>🇪🇺 GDPR Compliant</span>
        <span>📡 IoT & LoRaWAN</span>
        <span>🔒 {t.copy.includes('Europa') ? 'Datos en Europa' : 'Data in Europe'}</span>
      </div>
    </div>

    <!-- Col 1 -->
    <div class="footer-col">
      <h4>{t.col1_title}</h4>
      <a href="#como">{t.como}</a>
      <a href="https://panel.connect24.io/es/login" target="_blank" rel="noopener">{t.acceder}</a>
      <a href="https://go.connect24.io" target="_blank" rel="noopener">{t.go}</a>
    </div>

    <!-- Col 2 -->
    <div class="footer-col">
      <h4>{t.col2_title}</h4>
      <a href="/soluciones/operativa-tecnica">{t.sol1}</a>
      <a href="/soluciones/gestion-energetica">{t.sol2}</a>
      <a href="/soluciones/ciclo-del-agua">{t.sol3}</a>
      <a href="/soluciones/cool-protect">{t.sol5}</a>
      <a href="/soluciones/home-protect">{t.sol6}</a>
      <a href="/soluciones/gestion-tecnica-hotelera">{t.sol7}</a>
    </div>

    <!-- Col 3 -->
    <div class="footer-col">
      <h4>{t.col3_title}</h4>
      <a href="/nosotros/casos-de-exito">{t.emp1}</a>
      <a href="/nosotros/partners">{t.emp2}</a>
      <a href="/innovacion">{t.emp3}</a>
      <a href="/contacto">{t.emp4}</a>
    </div>

  </div>

  <div class="footer-bottom">
    <div class="container footer-bottom-inner">
      <p>{t.copy}</p>
      <div class="footer-bottom-links">
        <a href="mailto:hola@connect24.io">hola@connect24.io</a>
        <a href="tel:+34871153883">+34 871 153 883</a>
        <a href="https://www.connect24.io">www.connect24.io</a>
      </div>
    </div>
  </div>

</footer>

<style>
  .footer {
    background: var(--c24-navy);
    padding-top: 5rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1.5fr 1fr 1fr 1fr;
    gap: 3rem;
    padding-bottom: 4rem;
    border-bottom: 1px solid rgba(255,255,255,0.07);
  }

  .footer-brand {}

  .footer-logo {
    height: 40px; width: auto;
    margin-bottom: 1.25rem;
    filter: brightness(0) invert(1);
  }

  .footer-tagline {
    font-size: 0.85rem;
    color: rgba(255,255,255,0.4);
    line-height: 1.7; font-weight: 300;
    max-width: 260px;
    margin-bottom: 1.5rem;
  }

  .footer-badges {
    display: flex; flex-direction: column; gap: 0.4rem;
  }
  .footer-badges span {
    font-size: 0.75rem;
    color: rgba(255,255,255,0.3);
  }

  .footer-col {
    display: flex; flex-direction: column; gap: 0.65rem;
  }
  .footer-col h4 {
    font-family: var(--font-body);
    font-size: 0.75rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.35);
    margin-bottom: 0.6rem;
  }
  .footer-col a {
    font-size: 0.88rem;
    color: rgba(255,255,255,0.5);
    transition: color 0.15s;
  }
  .footer-col a:hover { color: var(--c24-teal); }

  .footer-bottom { padding: 1.5rem 0; }
  .footer-bottom-inner {
    display: flex; align-items: center;
    justify-content: space-between;
    flex-wrap: wrap; gap: 1rem;
  }
  .footer-bottom p {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.25);
  }
  .footer-bottom-links {
    display: flex; gap: 1.5rem; flex-wrap: wrap;
  }
  .footer-bottom-links a {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    transition: color 0.15s;
  }
  .footer-bottom-links a:hover { color: var(--c24-teal); }

  @media (max-width: 860px) {
    .footer-inner { grid-template-columns: 1fr 1fr; gap: 2rem; }
    .footer-brand { grid-column: 1 / -1; }
  }
  @media (max-width: 540px) {
    .footer-inner { grid-template-columns: 1fr; }
    .footer-bottom-inner { flex-direction: column; align-items: flex-start; }
  }
</style>