---
interface Props {
  t: {
    eyebrow: string;
    title1: string;
    title2: string;
    desc: string;
    step1_label: string;
    step1_title: string;
    step1_desc: string;
    step2_label: string;
    step2_title: string;
    step2_desc: string;
    step3_label: string;
    step3_title: string;
    step3_desc: string;
    remate1: string;
    remate2: string;
  };
}
const { t } = Astro.props;
---

<section class="como" id="como">
  <div class="container">

    <div class="como-header reveal">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2>{t.title1}<br/><em>{t.title2}</em></h2>
      <p class="section-desc">{t.desc}</p>
    </div>

    <div class="steps-grid">

      <div class="step reveal reveal-delay-1">
        <div class="step-num step-num--1">01</div>
        <span class="step-label">{t.step1_label}</span>
        <h3>{t.step1_title}</h3>
        <p>{t.step1_desc}</p>
      </div>

      <div class="step-arrow reveal reveal-delay-2">→</div>

      <div class="step reveal reveal-delay-2">
        <div class="step-num step-num--2">02</div>
        <span class="step-label">{t.step2_label}</span>
        <h3>{t.step2_title}</h3>
        <p>{t.step2_desc}</p>
      </div>

      <div class="step-arrow reveal reveal-delay-3">→</div>

      <div class="step reveal reveal-delay-3">
        <div class="step-num step-num--3">03</div>
        <span class="step-label">{t.step3_label}</span>
        <h3>{t.step3_title}</h3>
        <p>{t.step3_desc}</p>
      </div>

    </div>

    <p class="como-remate reveal">
      {t.remate1} <em>{t.remate2}</em>
    </p>

  </div>
</section>

<style>
  .como {
    padding: 7rem 2rem;
    background: var(--c24-surface);
    border-top: 1px solid var(--c24-border);
    border-bottom: 1px solid var(--c24-border);
  }

  .como-header {
    max-width: 620px;
    margin-bottom: 4rem;
  }
  .como-header h2 { margin-bottom: 1rem; }
  .como-header h2 em { font-style: italic; color: var(--c24-teal); }

  .steps-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr auto 1fr;
    gap: 1.5rem;
    align-items: start;
    margin-bottom: 4rem;
  }

  .step {
    background: var(--c24-bg);
    border: 1px solid var(--c24-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
    transition: border-color 0.25s, box-shadow 0.25s;
  }
  .step:hover {
    border-color: var(--c24-teal);
    box-shadow: 0 8px 32px rgba(69,191,162,0.08);
  }

  .step-num {
    width: 52px; height: 52px;
    border-radius: 50%;
    display: flex; align-items: center; justify-content: center;
    font-family: var(--font-body);
    font-weight: 700; font-size: 0.85rem;
    margin-bottom: 1.25rem;
    letter-spacing: 0.02em;
  }
  .step-num--1 { background: var(--c24-navy); color: var(--c24-teal); border: 2px solid var(--c24-teal); }
  .step-num--2 { background: var(--c24-teal); color: white; }
  .step-num--3 { background: var(--c24-teal-light); color: var(--c24-teal); border: 2px solid var(--c24-teal); }

  .step-label {
    display: block;
    font-size: 0.72rem; font-weight: 700;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: var(--c24-teal); margin-bottom: 0.5rem;
  }

  .step h3 {
    font-family: var(--font-display);
    font-size: 1.1rem; font-weight: 700;
    color: var(--c24-text);
    margin-bottom: 0.75rem;
    letter-spacing: -0.01em;
  }

  .step p {
    font-size: 0.9rem;
    color: var(--c24-text-muted);
    line-height: 1.7; font-weight: 300;
  }

  .step-arrow {
    font-size: 1.5rem;
    color: var(--c24-teal);
    opacity: 0.4;
    align-self: center;
    padding-top: 1rem;
  }

  .como-remate {
    text-align: center;
    font-family: var(--font-display);
    font-size: clamp(1.1rem, 2vw, 1.4rem);
    font-weight: 700;
    color: var(--c24-text);
    letter-spacing: -0.01em;
  }
  .como-remate em { font-style: italic; color: var(--c24-teal); }

  @media (max-width: 860px) {
    .steps-grid { grid-template-columns: 1fr; gap: 1rem; }
    .step-arrow { display: none; }
  }
  @media (max-width: 640px) {
    .como { padding: 5rem 1.5rem; }
  }
</style>