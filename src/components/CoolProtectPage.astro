/* ═══════════════════════════════════════════════
   MODAL DASHBOARD
═══════════════════════════════════════════════ */
.cp-modal-overlay {
  position: fixed; inset: 0; z-index: 9000;
  background: rgba(0, 20, 40, 0.7);
  backdrop-filter: blur(6px);
  display: flex; align-items: center; justify-content: center;
  padding: 1.5rem;
  opacity: 0; pointer-events: none;
  transition: opacity 0.25s ease;
}
.cp-modal-overlay.is-open {
  opacity: 1; pointer-events: all;
}
.cp-modal-box {
  position: relative;
  background: white;
  border-radius: 24px;
  overflow: hidden;
  width: 100%; max-width: 440px;
  box-shadow: 0 24px 80px rgba(0,20,40,0.35);
  transform: scale(0.92) translateY(16px);
  transition: transform 0.28s cubic-bezier(0.34,1.56,0.64,1);
}
:global([data-theme="dark"]) .cp-modal-box {
  background: var(--c24-surface);
  border: 1px solid var(--c24-border);
}
.cp-modal-overlay.is-open .cp-modal-box {
  transform: scale(1) translateY(0);
}
.cp-modal-body { padding: 2.5rem 2.5rem 3rem; }

/* Hint ampliar */
.cp-dash-card { cursor: pointer; }
.cp-dash-expand {
  display: flex; align-items: center; justify-content: center; gap: 0.3rem;
  margin-top: 0.6rem;
  font-size: 0.58rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase;
  color: white; background: var(--c24-teal);
  border-radius: 20px; padding: 0.25rem 0.7rem;
  opacity: 0.85;
  transition: opacity 0.2s, transform 0.15s;
  pointer-events: none; user-select: none;
}
.cp-dash-card:hover .cp-dash-expand {
  opacity: 1; transform: scale(1.05);
}
.cp-modal-body .cp-dash-expand { display: none; }

/* Card inside modal — override small-grid sizing */
.cp-modal-body .cp-dash-card {
  transform: none !important;
  box-shadow: none !important;
  border: none; border-radius: 0;
  padding: 0; cursor: default;
  width: 100%; text-align: center;
}
.cp-modal-body .cp-dash-card::after { display: none; }
.cp-modal-body .cp-dash-loc   { font-size: 0.72rem; }
.cp-modal-body .cp-dash-name  { font-size: 0.9rem; }
.cp-modal-body .cp-dash-status{ font-size: 0.75rem; }
.cp-modal-body .cp-dash-temp  { font-size: 3rem; margin-bottom: 1rem; }
.cp-modal-body .cp-dash-temp span { font-size: 1.2rem; }
.cp-modal-body .cp-bar-track  { height: 7px; border-radius: 4px; margin-bottom: 6px; }
.cp-modal-body .cp-bar-labels { font-size: 0.7rem; }
.cp-modal-body .cp-dash-row   { font-size: 0.78rem; gap: 1.5rem; justify-content: center; margin-bottom: 0.6rem; }
.cp-modal-body .cp-dash-hum   { font-size: 0.85rem; }
/* Color stripe at top of modal card */
.cp-modal-body .cp-dash-warning { border-top: 4px solid #f59e0b; padding-top: 0.75rem; }
.cp-modal-body .cp-dash-ok      { border-top: 4px solid #10b981; padding-top: 0.75rem; }
.cp-modal-body .cp-dash-critical{ border-top: 4px solid #ef4444; padding-top: 0.75rem; }
</style>

<script>
  const overlay = document.getElementById('cp-modal');
  const body    = overlay?.querySelector('.cp-modal-body');

  function openModal(card: HTMLElement) {
    if (!overlay || !body) return;
    body.innerHTML = '';
    const clone = card.cloneNode(true) as HTMLElement;
    clone.style.cssText = '';
    body.appendChild(clone);
    overlay.setAttribute('aria-hidden', 'false');
    overlay.classList.add('is-open');
    document.body.style.overflow = 'hidden';
  }

  function closeModal() {
    if (!overlay) return;
    overlay.classList.remove('is-open');
    overlay.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  const expandLabel = document.querySelector<HTMLElement>('.cp-dashboard')?.dataset.expand ?? '↗';

  document.querySelectorAll<HTMLElement>('.cp-dash-card').forEach(card => {
    const hint = document.createElement('div');
    hint.className = 'cp-dash-expand';
    hint.textContent = expandLabel;
    card.appendChild(hint);
    card.addEventListener('click', () => openModal(card));
  });

  overlay?.addEventListener('click', e => { if (e.target === overlay) closeModal(); });
  document.addEventListener('keydown', e => { if (e.key === 'Escape') closeModal(); });
</script>
