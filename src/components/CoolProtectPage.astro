---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
  lang: string;
}
const { t, lang } = Astro.props;
const tcp = t.coolprotect;
---
<Layout title={tcp.page_title} description={tcp.page_desc}>
  <Nav t={t.nav} lang={lang} />

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="cp-hero">
    <div class="cp-hero-inner">

      <div class="cp-hero-content">
        <div class="cp-sectors">
          {tcp.hero_sectors.map((s: string) => <span>{s}</span>)}
        </div>

        <h1 class="cp-hero-title">
          <span class="cp-ht-normal">{tcp.hero_title1}</span>
          <span class="cp-ht-accent">{tcp.hero_title2}</span>
        </h1>

        <p class="cp-hero-sub" set:html={tcp.hero_sub} />
        <p class="cp-hero-tagline">
          <span class="cp-flake">✳</span>
          {tcp.hero_tagline_pre} <strong>{tcp.hero_tagline_measure}</strong>{tcp.hero_tagline_mid} <strong class="accent">{tcp.hero_tagline_understand}</strong>.
        </p>

        <div class="cp-hero-actions">
          <a href="#precios" class="btn btn-primary">{tcp.hero_btn_plans}</a>
          <a href="#como-funciona" class="btn btn-ghost">{tcp.hero_btn_how}</a>
        </div>
      </div>

      <div class="cp-hero-visual" aria-hidden="true">
        <div class="cp-stage">
          <svg class="cp-conn" viewBox="0 0 640 340" preserveAspectRatio="none">
            <path class="cp-cl cp-cl1" d="M175,85 Q260,85 308,170"  fill="none" stroke="#f59e0b" stroke-width="1.5" stroke-dasharray="6 6"/>
            <path class="cp-cl cp-cl2" d="M175,255 Q260,255 308,170" fill="none" stroke="#10b981" stroke-width="1.5" stroke-dasharray="6 6"/>
            <path class="cp-cl cp-cl3" d="M465,85 Q380,85 332,170"  fill="none" stroke="#ef4444" stroke-width="1.5" stroke-dasharray="6 6"/>
            <path class="cp-cl cp-cl4" d="M465,255 Q380,255 332,170" fill="none" stroke="#10b981" stroke-width="1.5" stroke-dasharray="6 6"/>
          </svg>

          <div class="cp-cards-col cp-cards-left">
            <div class="cp-tcard cp-tcard--warn">
              <div class="cp-tc-top">
                <span class="cp-tc-loc">{tcp.hero_c1_loc}</span>
                <span class="cp-tc-status cp-ts-warn">● {tcp.dash_warning}</span>
              </div>
              <div class="cp-tc-temp">−15.9<span>ºC</span></div>
              <div class="cp-tc-name">{tcp.hero_c1_name}</div>
              <div class="cp-tc-hum">💧 67 %HR</div>
            </div>
            <div class="cp-tcard cp-tcard--ok">
              <div class="cp-tc-top">
                <span class="cp-tc-loc">{tcp.hero_c2_loc}</span>
                <span class="cp-tc-status cp-ts-ok">● {tcp.dash_ok}</span>
              </div>
              <div class="cp-tc-temp">4.8<span>ºC</span></div>
              <div class="cp-tc-name">{tcp.hero_c2_name}</div>
              <div class="cp-tc-hum">💧 84 %HR</div>
            </div>
          </div>

          <div class="cp-badge-center">
            <img src="/CoolProtect.svg" alt="Cool Protect" class="cp-shield-hero" />
          </div>

          <div class="cp-cards-col cp-cards-right">
            <div class="cp-tcard cp-tcard--crit">
              <div class="cp-tc-top">
                <span class="cp-tc-loc">{tcp.hero_c3_loc}</span>
                <span class="cp-tc-status cp-ts-crit">● {tcp.dash_critical}</span>
              </div>
              <div class="cp-tc-temp">+12.1<span>ºC</span></div>
              <div class="cp-tc-name">{tcp.hero_c3_name}</div>
              <div class="cp-tc-hum">💧 71 %HR</div>
            </div>
            <div class="cp-tcard cp-tcard--ok">
              <div class="cp-tc-top">
                <span class="cp-tc-loc">{tcp.hero_c4_loc}</span>
                <span class="cp-tc-status cp-ts-ok">● {tcp.dash_ok}</span>
              </div>
              <div class="cp-tc-temp">2.3<span>ºC</span></div>
              <div class="cp-tc-name">{tcp.hero_c4_name}</div>
              <div class="cp-tc-hum">💧 79 %HR</div>
            </div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       FEATURES
  ═══════════════════════════════════════════════ -->
  <section class="cp-features" id="como-funciona">
    <div class="container cp-features-inner">

      <div class="cp-features-left reveal">
        <span class="eyebrow">{tcp.feat_eyebrow}</span>
        <h2>{tcp.feat_title1}<br/>{tcp.feat_title2}</h2>
        <p class="section-desc" set:html={tcp.feat_desc} />
        <p class="cp-features-detail" set:html={tcp.feat_detail} />

        <ul class="cp-checklist">
          {tcp.feat_items.map((item: string) => (
            <li><span class="cp-check">✓</span>{item}</li>
          ))}
        </ul>
        <p class="cp-footnote">{tcp.feat_footnote}</p>
      </div>

      <div class="cp-features-right reveal reveal-delay-2">
        <div class="cp-dashboard" data-expand={tcp.dash_expand}>
          <div class="cp-dash-card cp-dash-warning">
            <div class="cp-dash-header">
              <span class="cp-dash-loc">{tcp.dash_c1_loc}</span>
              <span class="cp-dash-name">{tcp.dash_c1_name}</span>
              <span class="cp-dash-status cp-status-warning">● {tcp.dash_warning}</span>
            </div>
            <div class="cp-dash-temp">−15.9<span>ºC</span></div>
            <div class="cp-dash-bar">
              <div class="cp-bar-track"><div class="cp-bar-fill cp-bar-warn" style="left:10%;width:35%"></div></div>
              <div class="cp-bar-labels"><span>−22</span><span>VR −22/−18</span><span>−18</span></div>
            </div>
            <div class="cp-dash-row">
              <span>{tcp.dash_min} <strong>−16.4</strong></span>
              <span>{tcp.dash_med} <strong>−15.7</strong></span>
              <span>{tcp.dash_max} <strong>−14.9</strong></span>
            </div>
            <div class="cp-dash-hum">💧 67 %HR</div>
          </div>

          <div class="cp-dash-card cp-dash-ok">
            <div class="cp-dash-header">
              <span class="cp-dash-loc">{tcp.dash_c2_loc}</span>
              <span class="cp-dash-name">{tcp.dash_c2_name}</span>
              <span class="cp-dash-status cp-status-ok">● {tcp.dash_ok}</span>
            </div>
            <div class="cp-dash-temp">4.8<span>ºC</span></div>
            <div class="cp-dash-bar">
              <div class="cp-bar-track"><div class="cp-bar-fill cp-bar-ok" style="left:38%;width:28%"></div></div>
              <div class="cp-bar-labels"><span>0</span><span>VR 0/5</span><span>5</span></div>
            </div>
            <div class="cp-dash-row">
              <span>{tcp.dash_min} <strong>4.2</strong></span>
              <span>{tcp.dash_med} <strong>4.7</strong></span>
              <span>{tcp.dash_max} <strong>5.1</strong></span>
            </div>
            <div class="cp-dash-hum">💧 84 %HR</div>
          </div>

          <div class="cp-dash-card cp-dash-ok">
            <div class="cp-dash-header">
              <span class="cp-dash-loc">{tcp.dash_c3_loc}</span>
              <span class="cp-dash-name">{tcp.dash_c3_name}</span>
              <span class="cp-dash-status cp-status-ok">● {tcp.dash_ok}</span>
            </div>
            <div class="cp-dash-temp">13.5<span>ºC</span></div>
            <div class="cp-dash-bar">
              <div class="cp-bar-track"><div class="cp-bar-fill cp-bar-ok" style="left:28%;width:36%"></div></div>
              <div class="cp-bar-labels"><span>10</span><span>VR 10/18</span><span>18</span></div>
            </div>
            <div class="cp-dash-row">
              <span>{tcp.dash_min} <strong>12.9</strong></span>
              <span>{tcp.dash_med} <strong>13.4</strong></span>
              <span>{tcp.dash_max} <strong>14.1</strong></span>
            </div>
            <div class="cp-dash-hum">💧 55 %HR</div>
          </div>

          <div class="cp-dash-card cp-dash-warning">
            <div class="cp-dash-header">
              <span class="cp-dash-loc">{tcp.dash_c4_loc}</span>
              <span class="cp-dash-name">{tcp.dash_c4_name}</span>
              <span class="cp-dash-status cp-status-warning">● {tcp.dash_warning}</span>
            </div>
            <div class="cp-dash-temp">8.5<span>ºC</span></div>
            <div class="cp-dash-bar">
              <div class="cp-bar-track"><div class="cp-bar-fill cp-bar-warn" style="left:72%;width:20%"></div></div>
              <div class="cp-bar-labels"><span>0</span><span>VR 0/8</span><span>8</span></div>
            </div>
            <div class="cp-dash-row">
              <span>{tcp.dash_min} <strong>7.8</strong></span>
              <span>{tcp.dash_med} <strong>8.1</strong></span>
              <span>{tcp.dash_max} <strong>8.7</strong></span>
            </div>
            <div class="cp-dash-hum">💧 98 %HR</div>
          </div>

          <div class="cp-dash-card cp-dash-ok">
            <div class="cp-dash-header">
              <span class="cp-dash-loc">{tcp.dash_c5_loc}</span>
              <span class="cp-dash-name">{tcp.dash_c5_name}</span>
              <span class="cp-dash-status cp-status-ok">● {tcp.dash_ok}</span>
            </div>
            <div class="cp-dash-temp">8.3<span>ºC</span></div>
            <div class="cp-dash-bar">
              <div class="cp-bar-track"><div class="cp-bar-fill cp-bar-ok" style="left:30%;width:30%"></div></div>
              <div class="cp-bar-labels"><span>0</span><span>VR 0/10</span><span>10</span></div>
            </div>
            <div class="cp-dash-row">
              <span>{tcp.dash_min} <strong>7.6</strong></span>
              <span>{tcp.dash_med} <strong>8.2</strong></span>
              <span>{tcp.dash_max} <strong>8.9</strong></span>
            </div>
            <div class="cp-dash-hum">💧 62 %HR</div>
          </div>

          <div class="cp-dash-card cp-dash-critical">
            <div class="cp-dash-header">
              <span class="cp-dash-loc">{tcp.dash_c6_loc}</span>
              <span class="cp-dash-name">{tcp.dash_c6_name}</span>
              <span class="cp-dash-status cp-status-critical">● {tcp.dash_critical}</span>
            </div>
            <div class="cp-dash-temp">19.2<span>ºC</span></div>
            <div class="cp-dash-bar">
              <div class="cp-bar-track"><div class="cp-bar-fill cp-bar-crit" style="left:60%;width:40%"></div></div>
              <div class="cp-bar-labels"><span>10</span><span>VR 10/16</span><span>16</span></div>
            </div>
            <div class="cp-dash-row">
              <span>{tcp.dash_min} <strong>14.1</strong></span>
              <span>{tcp.dash_med} <strong>16.5</strong></span>
              <span>{tcp.dash_max} <strong>19.2</strong></span>
            </div>
            <div class="cp-dash-hum">💧 57 %HR</div>
          </div>
        </div>
      </div>

    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       SENSORES
  ═══════════════════════════════════════════════ -->
  <section class="cp-sensors">
    <div class="container">
      <div class="cp-sensors-header reveal">
        <span class="eyebrow">{tcp.sens_eyebrow}</span>
        <h2>{tcp.sens_title}</h2>
        <p class="section-desc" style="margin: 0 auto 3rem;">{tcp.sens_desc}</p>
      </div>

      <div class="cp-sensors-grid reveal reveal-delay-1">
        {tcp.sens_names.map((name: string, i: number) => (
          <div class="cp-sensor-item">
            <div class={`cp-sensor-card${i === 3 ? ' cp-sensor-card--starter' : ''}`}>
              <div class="cp-sensor-img-wrap">
                <img src={i === 3 ? '/sensor_coolprotect_2.png' : '/sensor_coolprotect.png'} alt={name} class={`cp-sensor-img${i === 3 ? ' cp-sensor-img--sm' : ''}`} />
                <div class="cp-sensor-label-side">{i < 3 ? 'Sensor Mod. LW - PRO' : 'Sensor Mod. BLE - STARTER'}</div>
              </div>
            </div>
            <span class="cp-sensor-name">{name}</span>
          </div>
        ))}
      </div>

      <div class="cp-notsolo reveal reveal-delay-2">
        <div class="cp-notsolo-text">
          <p class="cp-notsolo-big">
            {tcp.notsolo_line1}<br/>{tcp.notsolo_line2}<br/><span>{tcp.notsolo_accent}</span>
          </p>
          <p class="cp-notsolo-sub" set:html={tcp.notsolo_sub} />
        </div>
        <div class="cp-connectia">
          <img src="/ConnectIA.svg" alt="ConnectIA" class="cp-connectia-img" />
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       PRECIOS
  ═══════════════════════════════════════════════ -->
  <section class="cp-pricing" id="precios">
    <div class="container">
      <div class="cp-pricing-header reveal">
        <span class="eyebrow">{tcp.pricing_eyebrow}</span>
        <h2>{tcp.pricing_title1}<br/>{tcp.pricing_title2}</h2>
        <p class="section-desc" style="margin: 0 auto 3.5rem;">{tcp.pricing_desc}</p>
      </div>

      <div class="cp-plans reveal reveal-delay-1">

        <div class="cp-plan">
          <div class="cp-plan-name cp-plan-name--starter">{tcp.plan1_name}</div>
          <div class="cp-plan-cameras">{tcp.plan1_cameras}</div>
          <div class="cp-plan-price">
            <span class="cp-price-from">{tcp.plan_from}</span>
            <span class="cp-price-val">45€</span>
            <span class="cp-price-period">{tcp.plan_month}</span>
          </div>
          <p class="cp-plan-target">{tcp.plan1_target}</p>
          <ul class="cp-plan-features">
            {tcp.plan_feats.slice(0, 3).map((f: string) => <li>{f}</li>)}
          </ul>
          <div class="cp-plan-equipment">
            <strong>{tcp.plan_equip_base}</strong> {tcp.plan_equip_costs}<br/>{tcp.plan1_equip}
          </div>
          <a href="#contacto" class="btn btn-ghost cp-plan-cta">{tcp.plan1_cta}</a>
        </div>

        <div class="cp-plan cp-plan--popular">
          <div class="cp-popular-badge">{tcp.plan_popular}</div>
          <div class="cp-plan-name cp-plan-name--pro">{tcp.plan2_name}</div>
          <div class="cp-plan-cameras">{tcp.plan2_cameras}</div>
          <div class="cp-plan-price">
            <span class="cp-price-from">{tcp.plan_from}</span>
            <span class="cp-price-val">65€</span>
            <span class="cp-price-period">{tcp.plan_month}</span>
          </div>
          <p class="cp-plan-target">{tcp.plan2_target}</p>
          <ul class="cp-plan-features">
            {tcp.plan_feats.slice(0, 5).map((f: string) => <li>{f}</li>)}
          </ul>
          <div class="cp-plan-equipment">
            <strong>{tcp.plan_equip_base}</strong> {tcp.plan_equip_costs}<br/>{tcp.plan2_equip}
          </div>
          <a href="#contacto" class="btn btn-primary cp-plan-cta">{tcp.plan2_cta}</a>
        </div>

        <div class="cp-plan">
          <div class="cp-plan-name cp-plan-name--opera">{tcp.plan3_name}</div>
          <div class="cp-plan-cameras">{tcp.plan3_cameras}</div>
          <div class="cp-plan-price cp-plan-price--consultar">
            <span class="cp-price-val cp-price-val--consult">{tcp.plan_consult}</span>
          </div>
          <p class="cp-plan-target">{tcp.plan3_target}</p>
          <ul class="cp-plan-features">
            {tcp.plan_feats.map((f: string) => <li>{f}</li>)}
          </ul>
          <div class="cp-plan-equipment">
            <strong>{tcp.plan_equip_base}</strong> {tcp.plan_equip_costs}<br/>{tcp.plan3_equip}
          </div>
          <a href="#contacto" class="btn btn-navy cp-plan-cta">{tcp.plan3_cta}</a>
        </div>

      </div>
      <p class="cp-pricing-note reveal">{tcp.pricing_note}</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       CTA FINAL
  ═══════════════════════════════════════════════ -->
  <section class="cp-cta" id="contacto">
    <div class="container cp-cta-inner">
      <div class="cp-cta-text reveal">
        <h2 class="cp-cta-title">{tcp.cta_title}</h2>
        <p class="cp-cta-sub">{tcp.cta_sub}</p>
        <div class="cp-cta-contact">
          <a href="tel:+34871153883" class="cp-cta-link">+34 871 153 883</a>
          <span class="cp-cta-sep">|</span>
          <a href="mailto:info@connect24.io" class="cp-cta-link">info@connect24.io</a>
        </div>
        <a href="mailto:info@connect24.io" class="btn btn-white cp-cta-btn">{tcp.cta_btn}</a>
      </div>

      <div class="cp-cta-badge reveal reveal-delay-2" aria-hidden="true">
        <img src="/CoolProtect.svg" alt="Cool Protect" class="cp-cta-logo" />
        <p class="cp-cta-distinction" set:html={tcp.cta_distinction} />
      </div>
    </div>
  </section>

  <Footer t={t.footer} />

  <!-- Modal dashboard card -->
  <div id="cp-modal" class="cp-modal-overlay" aria-hidden="true" role="dialog" aria-modal="true">
    <div class="cp-modal-box">
      <div class="cp-modal-body"></div>
    </div>
  </div>
</Layout>

<style>
/* ═══════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════ */
.cp-hero {
  min-height: 100vh;
  display: flex; align-items: center;
  padding: 9rem 2rem 6rem;
  background: #f5f8fc;
  position: relative; overflow: hidden;
}
:global([data-theme="dark"]) .cp-hero {
  background: linear-gradient(135deg, #080F18 0%, #0a1520 55%, #080F18 100%);
}
.cp-hero::before {
  content: '';
  position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 55% 70% at 75% 50%, rgba(255,255,255,0.85) 0%, transparent 70%),
    radial-gradient(ellipse 30% 50% at 20% 60%, rgba(69,191,162,0.12) 0%, transparent 65%);
}
:global([data-theme="dark"]) .cp-hero::before {
  background:
    radial-gradient(ellipse 45% 65% at 75% 50%, rgba(69,191,162,0.18) 0%, transparent 70%),
    radial-gradient(ellipse 30% 50% at 20% 60%, rgba(0,60,91,0.30) 0%, transparent 65%);
}
.cp-hero-inner {
  position: relative; z-index: 1;
  max-width: 1200px; margin: 0 auto; width: 100%;
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 4rem; align-items: center;
}
.cp-sectors {
  display: flex; flex-wrap: wrap; gap: 0.5rem;
  margin-bottom: 1.75rem;
}
.cp-sectors span {
  font-size: 0.7rem; font-weight: 700;
  letter-spacing: 0.1em; text-transform: uppercase;
  padding: 0.3rem 0.8rem; border-radius: var(--radius-pill);
  background: rgba(69,191,162,0.12); color: var(--c24-teal-dark);
  border: 1px solid rgba(69,191,162,0.25);
}
.cp-hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.8rem, 4.5vw, 4.2rem);
  font-weight: 700; line-height: 1.1;
  letter-spacing: -0.02em; margin-bottom: 1.5rem;
}
.cp-ht-normal { display: block; color: var(--c24-navy); }
:global([data-theme="dark"]) .cp-ht-normal { color: #fff; }
.cp-ht-accent { display: block; color: var(--c24-teal); }
.cp-hero-sub {
  font-size: 1rem; color: var(--c24-text-muted);
  line-height: 1.8; font-weight: 300; max-width: 440px;
  margin-bottom: 0.75rem;
}
:global(.cp-hero-sub strong) { color: var(--c24-text); font-weight: 600; }
.cp-hero-tagline {
  font-size: 0.9rem; color: var(--c24-text-muted);
  font-weight: 300; margin-bottom: 2rem;
  display: flex; align-items: center; gap: 0.4rem; flex-wrap: wrap;
}
.cp-hero-tagline strong { font-weight: 600; }
.cp-hero-tagline strong.accent { color: var(--c24-teal); }
.cp-flake { color: var(--c24-teal); font-size: 1rem; }
.cp-hero-actions { display: flex; gap: 1rem; flex-wrap: wrap; }
.cp-hero-visual { display: flex; justify-content: center; align-items: center; }

/* ── Stage ── */
.cp-stage {
  position: relative;
  display: flex; align-items: center; justify-content: center;
  width: 100%; height: 340px;
}
.cp-cards-left  { margin-right: 45px; }
.cp-cards-right { margin-left: 45px; }

/* SVG connectors */
.cp-conn {
  position: absolute; inset: 0;
  width: 100%; height: 100%;
  pointer-events: none; overflow: visible; opacity: 0.55;
}
.cp-cl { animation: cpConnFlow 2.4s linear infinite; }
.cp-cl1 { animation-delay: 0s; }
.cp-cl2 { animation-delay: 0.35s; }
.cp-cl3 { animation-delay: 0.18s; }
.cp-cl4 { animation-delay: 0.52s; }
:global([data-theme="dark"]) .cp-conn { opacity: 0.8; }
@keyframes cpConnFlow {
  from { stroke-dashoffset: 18; }
  to   { stroke-dashoffset: 0; }
}

/* Cards column */
.cp-cards-col {
  display: flex; flex-direction: column;
  gap: 16px; z-index: 1; flex: 0 0 175px;
}

/* Temperature cards */
.cp-tcard {
  background: linear-gradient(150deg, #ffffff 0%, #f4f8fb 100%);
  border: 1px solid rgba(0,60,91,0.09);
  border-top: 1px solid rgba(255,255,255,0.95);
  border-radius: 14px; padding: 12px 14px;
  box-shadow: 0 1px 0 rgba(255,255,255,0.85) inset, 0 4px 8px rgba(0,60,91,0.06), 0 12px 28px rgba(0,60,91,0.10);
  display: flex; flex-direction: column; gap: 5px;
}
:global([data-theme="dark"]) .cp-tcard {
  background: linear-gradient(150deg, rgba(20,38,58,0.98) 0%, rgba(12,26,42,0.95) 100%);
  border-color: rgba(69,191,162,0.14);
  border-top-color: rgba(69,191,162,0.22);
  box-shadow: 0 1px 0 rgba(69,191,162,0.12) inset, 0 4px 8px rgba(0,0,0,0.20), 0 12px 28px rgba(0,0,0,0.28);
}
.cp-tcard--warn { border-left: 3px solid #f59e0b; }
