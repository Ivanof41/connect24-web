---
interface Props {
  t: {
    eyebrow: string;
    title1: string;
    title2: string;
    desc: string;
    tab1: string;
    tab2: string;
    tab3: string;
    label_hab: string;
    label_cam: string;
    label_res: string;
    seg_s: string;
    seg_m: string;
    seg_l: string;
    result_label: string;
    result_unit: string;
    result_desc: string;
    result_cta: string;
    desc_hotel: string;
    desc_cam: string;
    desc_res: string;
  };
}
const { t } = Astro.props;
---

<section class="calculadora" id="calculadora">
  <div class="calc-bg"></div>
  <div class="container calc-inner">

    <div class="calc-header reveal">
      <span class="eyebrow" style="color:var(--c24-teal)">{t.eyebrow}</span>
      <h2>{t.title1}<br/><em>{t.title2}</em></h2>
      <p class="section-desc">{t.desc}</p>
    </div>

    <div class="vertical-tabs reveal reveal-delay-1">
      <button class="vtab active" id="tab-hotel">{t.tab1}</button>
      <button class="vtab" id="tab-alimentacion">{t.tab2}</button>
      <button class="vtab" id="tab-residencial">{t.tab3}</button>
    </div>

    <div class="calc-box reveal reveal-delay-2">
      <div class="calc-layout">

        <!-- INPUT HOTEL -->
        <div id="input-hotel" class="calc-input">
          <div class="calc-label-row">
            <span class="calc-label-text">{t.label_hab}</span>
            <span class="calc-label-val" id="val-hab">100</span>
          </div>
          <input type="range" min="50" max="250" value="100" step="1" id="slider-hab" />
          <div class="slider-limits">
            <span style="left:0%;transform:none">50</span>
            <span style="left:25%">100</span>
            <span style="left:50%">150</span>
            <span style="left:75%">200</span>
            <span style="left:100%;transform:translateX(-100%)">250+</span>
          </div>
        </div>

        <!-- INPUT ALIMENTACIÓN -->
        <div id="input-alimentacion" class="calc-input" style="display:none">
          <div class="calc-label-row">
            <span class="calc-label-text">{t.label_cam}</span>
            <span class="calc-label-val" id="val-cam">10</span>
          </div>
          <input type="range" min="5" max="20" value="10" step="1" id="slider-cam" />
          <div class="slider-limits">
            <span style="left:0%;transform:none">5</span>
            <span style="left:33.3%">10</span>
            <span style="left:66.6%">15</span>
            <span style="left:100%;transform:translateX(-100%)">20+</span>
          </div>
        </div>

        <!-- INPUT RESIDENCIAL -->
        <div id="input-residencial" class="calc-input" style="display:none">
          <p class="calc-label-text" style="margin-bottom:1.25rem">{t.label_res}</p>
          <div class="segment-select">
            <button class="seg-btn active" data-seg="s">{t.seg_s}</button>
            <button class="seg-btn" data-seg="m">{t.seg_m}</button>
            <button class="seg-btn" data-seg="l">{t.seg_l}</button>
          </div>
        </div>

        <!-- RESULTADO -->
        <div class="calc-result">
          <p class="result-label">{t.result_label}</p>
          <div class="result-number" id="result-num">990</div>
          <p class="result-unit">{t.result_unit}</p>
          <p class="result-desc" id="result-desc">{t.result_desc}</p>
          <button class="btn btn-primary result-cta" id="resultCta">
            {t.result_cta}
          </button>
        </div>

      </div>
    </div>

  </div>
</section>

<style>
  .calculadora {
    padding: 7rem 2rem;
    background: var(--c24-navy);
    position: relative;
    overflow: hidden;
  }

  .calc-bg {
    position: absolute; inset: 0; pointer-events: none;
    background-image:
      linear-gradient(rgba(69,191,162,0.04) 1px, transparent 1px),
      linear-gradient(90deg, rgba(69,191,162,0.04) 1px, transparent 1px);
    background-size: 48px 48px;
  }
  :global([data-theme="dark"]) .calc-bg {
    background-image:
      linear-gradient(rgba(69,191,162,0.06) 1px, transparent 1px),
      linear-gradient(90deg, rgba(69,191,162,0.06) 1px, transparent 1px);
  }

  .calc-inner { position: relative; z-index: 1; }

  .calc-header { margin-bottom: 2.5rem; }
  .calc-header h2 { color: white; margin-bottom: 1rem; }
  .calc-header h2 em { font-style: italic; color: var(--c24-teal); }
  .calc-header .section-desc { color: rgba(255,255,255,0.45); }

  .vertical-tabs {
    display: flex; gap: 0.75rem;
    margin-bottom: 2rem; flex-wrap: wrap;
  }
  .vtab {
    padding: 0.65rem 1.4rem;
    border-radius: var(--radius-pill);
    font-family: var(--font-body);
    font-weight: 500; font-size: 0.88rem;
    border: 1.5px solid rgba(255,255,255,0.15);
    color: rgba(255,255,255,0.5);
    background: transparent; cursor: pointer;
    transition: all 0.2s;
  }
  .vtab:hover:not(.active) {
    border-color: rgba(255,255,255,0.3);
    color: rgba(255,255,255,0.8);
  }
  .vtab.active {
    background: var(--c24-teal);
    border-color: var(--c24-teal);
    color: white;
  }

  .calc-box {
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(69,191,162,0.2);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
  }
  .calc-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 3rem; align-items: center;
  }

  .calc-label-row {
    display: flex; justify-content: space-between;
    align-items: center; margin-bottom: 1rem;
  }
  .calc-label-text { font-size: 0.88rem; color: rgba(255,255,255,0.6); }
  .calc-label-val {
    font-family: var(--font-display);
    font-weight: 700; font-size: 1.1rem;
    color: var(--c24-teal);
  }

  input[type="range"] {
    width: 100%; -webkit-appearance: none;
    height: 4px;
    background: linear-gradient(to right, var(--c24-teal) 25%, rgba(255,255,255,0.15) 25%);
    border-radius: 2px; outline: none; margin-bottom: 0.75rem;
    transition: background 0.15s;
  }
  input[type="range"]::-webkit-slider-thumb {
    -webkit-appearance: none;
    width: 20px; height: 20px; border-radius: 50%;
    background: var(--c24-teal); cursor: pointer;
    border: 3px solid var(--c24-navy);
    transition: transform 0.15s;
  }
  input[type="range"]::-webkit-slider-thumb:hover { transform: scale(1.2); }

  .slider-limits {
    position: relative;
    height: 1.2rem;
    margin-top: 0.5rem;
  }
  .slider-limits span {
    position: absolute;
    font-size: 0.72rem;
    color: rgba(255,255,255,0.3);
    transform: translateX(-50%);
  }

  .segment-select { display: flex; flex-direction: column; gap: 0.65rem; }
  .seg-btn {
    padding: 0.8rem 1.2rem; border-radius: var(--radius-md);
    background: rgba(255,255,255,0.04);
    border: 1.5px solid rgba(255,255,255,0.1);
    color: rgba(255,255,255,0.55);
    font-family: var(--font-body); font-size: 0.9rem;
    cursor: pointer; transition: all 0.2s; text-align: left;
  }
  .seg-btn:hover:not(.active) {
    border-color: rgba(255,255,255,0.25);
    color: rgba(255,255,255,0.8);
  }
  .seg-btn.active {
    background: rgba(69,191,162,0.15);
    border-color: var(--c24-teal); color: white;
  }

  .calc-result {
    background: rgba(69,191,162,0.08);
    border: 1px solid rgba(69,191,162,0.2);
    border-radius: var(--radius-lg);
    padding: 2.5rem; text-align: center;
  }
  .result-label {
    font-size: 0.75rem; font-weight: 600;
    letter-spacing: 0.1em; text-transform: uppercase;
    color: rgba(255,255,255,0.4); margin-bottom: 0.75rem;
  }
  .result-number {
    font-family: var(--font-display);
    font-size: clamp(3.5rem, 6vw, 5rem);
    font-weight: 700; color: var(--c24-teal);
    letter-spacing: -0.03em; line-height: 1;
    margin-bottom: 0.25rem;
    transition: all 0.3s var(--ease-out);
  }
  .result-unit {
    font-size: 0.9rem; color: rgba(255,255,255,0.4);
    margin-bottom: 1rem;
  }
  .result-desc {
    font-size: 0.82rem; color: rgba(255,255,255,0.35);
    line-height: 1.6; margin-bottom: 1.75rem; min-height: 2.5rem;
  }
  .result-cta { width: 100%; justify-content: center; }

  @media (max-width: 768px) {
    .calc-layout { grid-template-columns: 1fr; }
    .calc-box { padding: 1.75rem; }
    .calculadora { padding: 5rem 1.5rem; }
  }

  @media (max-width: 480px) {
    .calc-box { padding: 1.25rem; }
    .slider-limits span { font-size: 0.62rem; }
    .vertical-tabs { gap: 0.5rem; }
    .vtab { padding: 0.55rem 1rem; font-size: 0.82rem; }
    .calc-result { padding: 1.5rem 1.25rem; }
  }
</style>

<script define:vars={{ descHotel: t.desc_hotel, descCam: t.desc_cam, descRes: t.desc_res, resultDesc: t.result_desc }}>
  const anclaHotel = [
    { x: 50,  y: 610  },
    { x: 100, y: 990  },
    { x: 150, y: 1440 },
    { x: 200, y: 1735 },
    { x: 250, y: 2030 },
  ];
  const anclaAlimentacion = [
    { x: 5,  y: 85  },
    { x: 10, y: 134 },
    { x: 15, y: 158 },
    { x: 20, y: 195 },
  ];
  const horasResidencial = { s: 45, m: 85, l: 145 };

  let currentVertical = 'hotel';
  let currentSegmento = 's';

  function interpolar(val, anclas) {
    if (val <= anclas[0].x) return anclas[0].y;
    if (val >= anclas[anclas.length - 1].x) return anclas[anclas.length - 1].y;
    for (let i = 0; i < anclas.length - 1; i++) {
      const a = anclas[i];
      const b = anclas[i + 1];
      if (val >= a.x && val <= b.x) {
        const t = (val - a.x) / (b.x - a.x);
        return Math.round(a.y + t * (b.y - a.y));
      }
    }
    return anclas[0].y;
  }

  function updateSliderTrack(input, min, max) {
    const pct = ((parseInt(input.value) - min) / (max - min)) * 100;
    input.style.background = `linear-gradient(to right, var(--c24-teal) ${pct}%, rgba(255,255,255,0.15) ${pct}%)`;
  }

  document.querySelectorAll('.vtab').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.vtab').forEach(t => t.classList.remove('active'));
      btn.classList.add('active');
      const id = btn.id.replace('tab-', '');
      currentVertical = id;
      ['hotel', 'alimentacion', 'residencial'].forEach(v => {
        const el = document.getElementById(`input-${v}`);
        if (el) el.style.display = v === id ? 'block' : 'none';
      });
      calcular();
    });
  });

  const sliderHab = document.getElementById('slider-hab');
  sliderHab?.addEventListener('input', (e) => {
    const val = parseInt(e.target.value);
    updateSliderTrack(e.target, 50, 250);
    const display = document.getElementById('val-hab');
    if (display) display.textContent = val === 250 ? '250+' : String(val);
    calcular();
  });

  const sliderCam = document.getElementById('slider-cam');
  sliderCam?.addEventListener('input', (e) => {
    const val = parseInt(e.target.value);
    updateSliderTrack(e.target, 5, 20);
    const display = document.getElementById('val-cam');
    if (display) display.textContent = val === 20 ? '20+' : String(val);
    calcular();
  });

  document.querySelectorAll('.seg-btn').forEach(btn => {
    btn.addEventListener('click', () => {
      document.querySelectorAll('.seg-btn').forEach(b => b.classList.remove('active'));
      btn.classList.add('active');
      currentSegmento = btn.getAttribute('data-seg') || 's';
      calcular();
    });
  });

  function calcular() {
    let horas = 0;
    let desc  = resultDesc;

    if (currentVertical === 'hotel') {
      const val = parseInt(document.getElementById('slider-hab').value);
      horas = interpolar(val, anclaHotel);
      desc  = `${val === 250 ? '250+' : val} ${descHotel}`;
    } else if (currentVertical === 'alimentacion') {
      const val = parseInt(document.getElementById('slider-cam').value);
      horas = interpolar(val, anclaAlimentacion);
      desc  = `${val === 20 ? '20+' : val} ${descCam}`;
    } else {
      horas = horasResidencial[currentSegmento] || 85;
      desc  = descRes;
    }

    const numEl  = document.getElementById('result-num');
    const descEl = document.getElementById('result-desc');
    if (numEl)  numEl.textContent  = horas.toLocaleString('es-ES');
    if (descEl) descEl.textContent = desc;
  }

  if (sliderHab) updateSliderTrack(sliderHab, 50, 250);
  if (sliderCam) updateSliderTrack(sliderCam, 5, 20);

  document.getElementById('resultCta')?.addEventListener('click', () => {
    const sliderHabEl = document.getElementById('slider-hab');
    const sliderCamEl = document.getElementById('slider-cam');
    const payload = {
      vertical:  currentVertical,
      segmento:  currentSegmento,
      habValue:  sliderHabEl ? parseInt(sliderHabEl.value) : 100,
      camValue:  sliderCamEl ? parseInt(sliderCamEl.value) : 10,
    };
    document.dispatchEvent(new CustomEvent('openModalFromCalc', { detail: payload }));
    document.getElementById('modal')?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });

  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });
  reveals.forEach(el => observer.observe(el));

  calcular();
</script>