---
---

<div class="modal-overlay" id="modal">
  <div class="modal">
    <button class="modal-close" id="modalClose" aria-label="Cerrar">✕</button>

    <div class="modal-body" id="modalBody">
      <h3>Libera tu equipo</h3>
      <p class="modal-sub">
        Cuéntanos tu instalación. Te respondemos en menos de 24h con un plan concreto.
      </p>

      <div class="form-row">
        <div class="form-group">
          <label>Nombre</label>
          <input type="text" placeholder="Tu nombre" />
        </div>
        <div class="form-group">
          <label>Empresa</label>
          <input type="text" placeholder="Nombre del negocio" />
        </div>
      </div>
      <div class="form-group">
        <label>Email</label>
        <input type="email" placeholder="tu@empresa.com" />
      </div>
      <div class="form-group">
        <label>Teléfono</label>
        <input type="tel" placeholder="+34 600 000 000" />
      </div>
      <div class="form-group">
        <label>Tipo de instalación</label>
        <select>
          <option value="">Selecciona...</option>
          <option>Hotel / Agroturismo</option>
          <option>Restaurante / Catering / Alimentación</option>
          <option>Residencial / Vacacional</option>
          <option>Instalación deportiva</option>
          <option>Otro</option>
        </select>
      </div>

      <button class="btn btn-primary btn-submit" id="modalSubmit">
        Quiero liberar horas →
      </button>
      <p class="modal-privacy">Sin compromiso · Te respondemos en menos de 24h</p>
    </div>

  </div>
</div>

<style>
  .modal-overlay {
    display: none;
    position: fixed; inset: 0;
    background: rgba(8,15,24,0.85);
    z-index: 200;
    align-items: center;
    justify-content: center;
    padding: 1rem;
    backdrop-filter: blur(6px);
  }
  .modal-overlay.active { display: flex; }

  .modal {
    background: var(--c24-surface);
    border: 1px solid var(--c24-border);
    border-radius: var(--radius-lg);
    padding: 2.5rem;
    max-width: 520px; width: 100%;
    position: relative;
    animation: modalIn 0.25s var(--ease-out);
  }

  @keyframes modalIn {
    from { opacity: 0; transform: translateY(20px) scale(0.97); }
    to   { opacity: 1; transform: translateY(0) scale(1); }
  }

  .modal-close {
    position: absolute; top: 1.25rem; right: 1.25rem;
    width: 32px; height: 32px; border-radius: 50%;
    background: var(--c24-bg);
    border: 1px solid var(--c24-border);
    color: var(--c24-text-muted);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.85rem; cursor: pointer;
    transition: border-color 0.15s, color 0.15s;
  }
  .modal-close:hover {
    border-color: var(--c24-teal);
    color: var(--c24-teal);
  }

  h3 {
    font-family: var(--font-display);
    font-size: 1.5rem; font-weight: 700;
    color: var(--c24-text);
    margin-bottom: 0.5rem;
    letter-spacing: -0.02em;
  }

  .modal-sub {
    font-size: 0.9rem;
    color: var(--c24-text-muted);
    margin-bottom: 1.75rem;
    line-height: 1.6;
  }

  .form-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 1rem;
  }

  .form-group {
    margin-bottom: 1rem;
  }
  .form-group label {
    display: block;
    font-size: 0.75rem; font-weight: 600;
    color: var(--c24-text-muted);
    margin-bottom: 0.4rem;
    text-transform: uppercase;
    letter-spacing: 0.06em;
  }
  .form-group input,
  .form-group select {
    width: 100%;
    padding: 0.75rem 1rem;
    border: 1.5px solid var(--c24-border);
    border-radius: var(--radius-sm);
    font-family: var(--font-body);
    font-size: 0.9rem;
    color: var(--c24-text);
    background: var(--c24-bg);
    transition: border-color 0.15s;
    outline: none;
    -webkit-appearance: none;
  }
  .form-group input:focus,
  .form-group select:focus {
    border-color: var(--c24-teal);
    box-shadow: 0 0 0 3px rgba(0,180,160,0.1);
  }

  .btn-submit {
    width: 100%;
    justify-content: center;
    margin-top: 0.5rem;
  }

  .modal-privacy {
    text-align: center;
    font-size: 0.75rem;
    color: var(--c24-text-muted);
    margin-top: 1rem;
    opacity: 0.6;
  }

  /* ── Responsive ── */
  @media (max-width: 540px) {
    .modal { padding: 2rem 1.5rem; }
    .form-row { grid-template-columns: 1fr; }
  }
</style>

<script>
  // Cerrar con botón
  document.getElementById('modalClose')?.addEventListener('click', () => {
    document.getElementById('modal')?.classList.remove('active');
    document.body.style.overflow = '';
  });

  // Cerrar clickando fuera
  document.getElementById('modal')?.addEventListener('click', (e) => {
    if (e.target === document.getElementById('modal')) {
      document.getElementById('modal')?.classList.remove('active');
      document.body.style.overflow = '';
    }
  });

  // Cerrar con Escape
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.getElementById('modal')?.classList.remove('active');
      document.body.style.overflow = '';
    }
  });

  // Submit
  document.getElementById('modalSubmit')?.addEventListener('click', () => {
    const body = document.getElementById('modalBody');
    if (!body) return;
    body.innerHTML = `
      <div style="text-align:center;padding:2rem 0">
        <div style="width:64px;height:64px;border-radius:50%;
          background:rgba(0,180,160,0.12);
          display:flex;align-items:center;justify-content:center;
          font-size:1.75rem;margin:0 auto 1.5rem;color:var(--c24-teal)">✓</div>
        <h3 style="margin-bottom:0.75rem">¡Recibido!</h3>
        <p style="color:var(--c24-text-muted);font-size:0.92rem;line-height:1.6;
          max-width:320px;margin:0 auto 2rem">
          Te contactamos en menos de 24h para ver exactamente cuántas
          horas puede liberar tu instalación.
        </p>
        <button
          onclick="document.getElementById('modal').classList.remove('active');document.body.style.overflow='';"
          class="btn btn-primary"
          style="margin:0 auto"
        >
          Cerrar
        </button>
      </div>`;
  });
</script>