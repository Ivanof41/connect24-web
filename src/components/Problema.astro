---
interface Props {
  t: {
    eyebrow: string;
    title: string;
    desc: string;
    items: string[];
    remate1: string;
    remate2: string;
    remate3: string;
    cta: string;
  };
}
const { t } = Astro.props;
---

<section class="problema" id="problema">
  <div class="container">

    <div class="problema-header reveal">
      <span class="eyebrow">{t.eyebrow}</span>
      <h2>{t.title}</h2>
      <p class="section-desc">{t.desc}</p>
    </div>

    <div class="checklist reveal reveal-delay-1">
      {t.items.map((item) => (
        <div class="check-item">
          <span class="check-icon">✓</span>
          <span>{item}</span>
        </div>
      ))}
    </div>

    <div class="problema-remate reveal reveal-delay-2">
      <p class="remate-text">
        {t.remate1} <em>{t.remate2}</em>.<br/>{t.remate3}
      </p>
      <a href="#calculadora" class="btn btn-primary">{t.cta}</a>
    </div>

  </div>
</section>

<style>
  .problema {
    padding: 7rem 2rem;
    background: var(--c24-bg);
  }

  .problema-header {
    max-width: 620px;
    margin-bottom: 3.5rem;
  }
  .problema-header h2 { margin-bottom: 1rem; }

  .checklist {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
    gap: 0.75rem;
    margin-bottom: 3.5rem;
  }

  .check-item {
    display: flex;
    align-items: center;
    gap: 0.85rem;
    padding: 0.9rem 1.1rem;
    background: var(--c24-surface);
    border: 1px solid var(--c24-border);
    border-radius: var(--radius-md);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .check-item:hover {
    border-color: var(--c24-teal);
    box-shadow: 0 4px 16px rgba(69,191,162,0.08);
  }

  .check-icon {
    width: 28px; height: 28px;
    border-radius: 50%;
    background: rgba(69,191,162,0.1);
    color: var(--c24-teal);
    display: flex; align-items: center; justify-content: center;
    font-size: 0.78rem; font-weight: 700;
    flex-shrink: 0;
  }

  .check-item span:last-child {
    font-size: 0.9rem;
    color: var(--c24-text);
    font-weight: 400;
    line-height: 1.4;
  }

  .problema-remate {
    background: var(--c24-navy);
    border-radius: var(--radius-lg);
    padding: 2.5rem 3rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    flex-wrap: wrap;
  }
  :global([data-theme="dark"]) .problema-remate {
    background: var(--c24-surface);
    border: 1px solid var(--c24-border);
  }

  .remate-text {
    font-family: var(--font-display);
    font-size: clamp(1.2rem, 2vw, 1.5rem);
    font-weight: 700;
    color: white;
    line-height: 1.4;
  }
  :global([data-theme="dark"]) .remate-text { color: var(--c24-text); }
  .remate-text em { font-style: italic; color: var(--c24-teal); }

  @media (max-width: 640px) {
    .problema { padding: 5rem 1.5rem; }
    .problema-remate { flex-direction: column; align-items: flex-start; padding: 2rem; }
    .problema-remate .btn { width: 100%; justify-content: center; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });
  reveals.forEach(el => observer.observe(el));
</script>