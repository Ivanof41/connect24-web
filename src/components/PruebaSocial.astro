---
---

<section class="social">
  <div class="container">

    <div class="social-header reveal">
      <span class="eyebrow">Reconocimientos</span>
      <h2>Avalados por quienes importan.</h2>
    </div>

    <div class="badges reveal reveal-delay-1">
      <div class="badge">
        <span class="badge-dot"></span>
        Lanzadera
      </div>
      <div class="badge">
        <span class="badge-dot"></span>
        ENISA — Empresa Emergente
      </div>
      <div class="badge">
        <span class="badge-dot"></span>
        Premios CAEB-Santander
      </div>
      <div class="badge">
        <span class="badge-dot"></span>
        Cofinanciado por la UE
      </div>
    </div>

    <div class="kit-digital reveal reveal-delay-2">
      <img
        src="/Kit.png"
        alt="Kit Digital — Cofinanciado por la Unión Europea"
        class="kit-img kit-img--light"
      />
      <img
        src="/KitDigital.png"
        alt="Kit Digital — Cofinanciado por la Unión Europea"
        class="kit-img kit-img--dark"
      />
    </div>

  </div>
</section>

<style>
  .social {
    padding: 6rem 2rem;
    background: var(--c24-surface);
    border-top: 1px solid var(--c24-border);
    border-bottom: 1px solid var(--c24-border);
  }

  .social-header {
    text-align: center;
    margin-bottom: 2.5rem;
  }
  .social-header h2 { margin-bottom: 0; }

  /* ── Badges ── */
  .badges {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    margin-bottom: 3rem;
  }

  .badge {
    display: flex; align-items: center; gap: 0.5rem;
    background: var(--c24-bg);
    border: 1px solid var(--c24-border);
    border-radius: var(--radius-pill);
    padding: 0.55rem 1.2rem;
    font-size: 0.85rem;
    font-weight: 500;
    color: var(--c24-text-muted);
    transition: border-color 0.2s, color 0.2s, box-shadow 0.2s;
  }
  .badge:hover {
    border-color: var(--c24-teal);
    color: var(--c24-text);
    box-shadow: 0 4px 16px rgba(0,180,160,0.08);
  }

  .badge-dot {
    width: 7px; height: 7px;
    border-radius: 50%;
    background: var(--c24-teal);
    flex-shrink: 0;
    animation: glowTeal 2.5s ease-in-out infinite;
  }

  /* ── Kit Digital ── */
  .kit-digital {
    display: flex;
    justify-content: center;
  }

  .kit-img {
    max-width: 680px;
    width: 100%;
    opacity: 0.75;
    transition: opacity 0.2s, filter 0.2s;
    filter: grayscale(20%);
  }
  .kit-img:hover {
    opacity: 1;
    filter: grayscale(0%);
  }

  /* Claro: Kit.png visible, KitDigital.png oculto */
  .kit-img--light { display: block; }
  .kit-img--dark  { display: none; }

  /* Oscuro: KitDigital.png visible, Kit.png oculto */
  :global([data-theme="dark"]) .kit-img--light { display: none; }
  :global([data-theme="dark"]) .kit-img--dark  { display: block; }

  @keyframes glowTeal {
    0%, 100% { box-shadow: 0 0 3px rgba(0,180,160,0.4); }
    50%       { box-shadow: 0 0 8px 2px rgba(0,180,160,0.7); }
  }

  /* ── Responsive ── */
  @media (max-width: 640px) {
    .social { padding: 4rem 1.5rem; }
    .badges { gap: 0.75rem; }
    .badge  { font-size: 0.8rem; padding: 0.45rem 1rem; }
  }
</style>

<script>
  const reveals = document.querySelectorAll('.reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });
  reveals.forEach(el => observer.observe(el));
</script>