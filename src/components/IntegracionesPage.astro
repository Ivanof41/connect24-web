---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
  lang: string;
}
const { t, lang } = Astro.props;
const tg = t.integraciones;

const icons: Record<string, string> = {
  server: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="8" rx="2"/><rect x="2" y="13" width="20" height="8" rx="2"/><line x1="6" y1="7" x2="6.01" y2="7"/><line x1="6" y1="17" x2="6.01" y2="17"/></svg>`,
  building: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="22" x2="10" y2="15"/><line x1="14" y1="22" x2="14" y2="15"/></svg>`,
  wrench: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  euro: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 7.5a6.5 6.5 0 1 0 0 9"/><line x1="3.5" y1="10" x2="13.5" y2="10"/><line x1="3.5" y1="14" x2="12" y2="14"/></svg>`,
  external: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
  trending: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  grid: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  wifi: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
  plug: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2v4M15 2v4"/><path d="M6 8h12v4a6 6 0 0 1-12 0V8z"/><path d="M12 18v4"/></svg>`,
  refresh: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 4 23 10 17 10"/><polyline points="1 20 1 14 7 14"/><path d="M3.51 9a9 9 0 0 1 14.85-3.36L23 10M1 14l4.64 4.36A9 9 0 0 0 20.49 15"/></svg>`,
  users: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  shieldcheck: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  cloud: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h.79a4.5 4.5 0 1 1 0 9z"/></svg>`,
  database: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>`,
  more: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg>`,
  checkcircle: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  alert: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  clock: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  star: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  filetext: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  mqtt: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><path d="M7 6h10M7 6L5 18M19 6l-2 12"/></svg>`,
  activity: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  settings: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
};

const s1items = [
  { title: tg.s1_item1_title, desc: tg.s1_item1_desc, icon: 'plug' },
  { title: tg.s1_item2_title, desc: tg.s1_item2_desc, icon: 'refresh' },
  { title: tg.s1_item3_title, desc: tg.s1_item3_desc, icon: 'users' },
];
const s2items = [
  { title: tg.s2_item1_title, desc: tg.s2_item1_desc, icon: 'plug' },
  { title: tg.s2_item2_title, desc: tg.s2_item2_desc, icon: 'shieldcheck' },
  { title: tg.s2_item3_title, desc: tg.s2_item3_desc, icon: 'trending' },
];
const s3items = [
  { title: tg.s3_item1_title, desc: tg.s3_item1_desc, icon: 'database' },
  { title: tg.s3_item2_title, desc: tg.s3_item2_desc, icon: 'refresh' },
  { title: tg.s3_item3_title, desc: tg.s3_item3_desc, icon: 'grid' },
];

// Docking arc (8 nodes) — unlike Conecta 360's full 360° ring, the systems
// arrive from a left-hand arc into an off-center hub, like ships docking in
// from one side. Same edge-stop technique so lines never cross the labels.
const ICON_R = 9;
const HUB_X = 66, HUB_Y = 50;
const rawNodes = [
  { label: tg.s1_node1, x: 66,   y: 10,   icon: 'server' },
  { label: tg.s1_node2, x: 48.6, y: 14,   icon: 'building' },
  { label: tg.s1_node3, x: 34.7, y: 25.1, icon: 'wrench' },
  { label: tg.s1_node4, x: 27,   y: 41.1, icon: 'euro' },
  { label: tg.s1_node5, x: 27,   y: 58.9, icon: 'external' },
  { label: tg.s1_node6, x: 34.7, y: 74.9, icon: 'trending' },
  { label: tg.s1_node7, x: 48.6, y: 86,   icon: 'grid' },
  { label: tg.s1_node8, x: 66,   y: 90,   icon: 'wifi' },
];
const nodes = rawNodes.map(n => {
  const dx = n.x - HUB_X, dy = n.y - HUB_Y;
  const dist = Math.sqrt(dx * dx + dy * dy);
  const lineX = n.x - (dx / dist) * ICON_R;
  const lineY = n.y - (dy / dist) * ICON_R;
  return { ...n, lineX, lineY };
});

const protocols = [
  { label: tg.s2_p1, icon: 'cloud' },
  { label: tg.s2_p2, icon: 'mqtt' },
  { label: tg.s2_p3, icon: 'building' },
  { label: tg.s2_p4, icon: 'activity' },
  { label: tg.s2_p5, icon: 'database' },
  { label: tg.s2_p6, icon: 'more' },
];
const navItems = [tg.s2_nav1, tg.s2_nav2, tg.s2_nav3, tg.s2_nav4, tg.s2_nav5];
const connectorRows = [
  { name: tg.s2_row1, sync: tg.s2_row1_sync, icon: 'building' },
  { name: tg.s2_row2, sync: tg.s2_row2_sync, icon: 'wrench' },
  { name: tg.s2_row3, sync: tg.s2_row3_sync, icon: 'server' },
  { name: tg.s2_row4, sync: tg.s2_row4_sync, icon: 'euro' },
  { name: tg.s2_row5, sync: tg.s2_row5_sync, icon: 'cloud' },
];

const sources = [
  { label: tg.s3_source1, icon: 'server' },
  { label: tg.s3_source2, icon: 'wifi' },
  { label: tg.s3_source3, icon: 'euro' },
  { label: tg.s3_source4, icon: 'grid' },
  { label: tg.s3_source5, icon: 'external' },
];
const destinations = [
  { label: tg.s3_dest1, icon: 'building' },
  { label: tg.s3_dest2, icon: 'wrench' },
  { label: tg.s3_dest3, icon: 'trending' },
  { label: tg.s3_dest4, icon: 'euro' },
  { label: tg.s3_dest5, icon: 'external' },
];
const stats3 = [
  { val: tg.s3_stat1_val, label: tg.s3_stat1_label, icon: 'trending' },
  { val: tg.s3_stat2_val, label: tg.s3_stat2_label, icon: 'alert' },
  { val: tg.s3_stat3_val, label: tg.s3_stat3_label, icon: 'clock' },
  { val: tg.s3_stat4_val, label: tg.s3_stat4_label, icon: 'checkcircle' },
];

const benefits4 = [
  { label: tg.s4_benefit1, icon: 'settings' },
  { label: tg.s4_benefit2, icon: 'checkcircle' },
  { label: tg.s4_benefit3, icon: 'filetext' },
  { label: tg.s4_benefit4, icon: 'star' },
  { label: tg.s4_benefit5, icon: 'trending' },
];
---
<Layout title={tg.page_title} description={tg.page_desc}>
  <Nav t={t.nav} lang={lang} />

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="ig-hero">
    <div class="container ig-hero-inner reveal">
      <span class="ig-eyebrow-badge">{tg.hero_eyebrow}</span>
      <h1 class="ig-hero-title">{tg.hero_title}</h1>
      <p class="ig-hero-sub">{tg.hero_sub}</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       01 · UN ECOSISTEMA CONECTADO
  ═══════════════════════════════════════════════ -->
  <section class="ig-section ig-bg-a">
    <div class="container ig-grid">
      <div class="ig-text reveal">
        <div class="ig-num-row">
          <span class="ig-num">{tg.s1_num}</span>
          <span class="eyebrow" style="margin:0;">{tg.s1_eyebrow}</span>
        </div>
        <h2>{tg.s1_title1}<br/><em>{tg.s1_title2}</em></h2>
        <p class="section-desc">{tg.s1_desc}</p>
        <ul class="ig-list">
          {s1items.map(item => (
            <li>
              <span class="ig-list-icon" set:html={icons[item.icon]} />
              <span class="ig-list-text"><strong>{item.title}</strong><br/>{item.desc}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="ig-visual reveal reveal-delay-2">
        <div class="ig-radial">
          <svg class="ig-radial-conn" viewBox="0 0 100 100" preserveAspectRatio="none">
            {nodes.map((n, i) => (
              <path class={`ig-rl ig-rl${i}`} d={`M${n.lineX},${n.lineY} L${HUB_X},${HUB_Y}`} fill="none" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2.2 2.2"/>
            ))}
          </svg>
          <div class="ig-radial-center">
            <span class="ig-center-logo"><img src="/maindhotel_icono.svg" alt="MaindHotel" /></span>
            <span class="ig-center-name">{tg.s1_center_name}</span>
            <span class="ig-center-sub">{tg.s1_center_sub}</span>
          </div>
          {nodes.map(n => (
            <div class="ig-node" style={`left:${n.x}%; top:${n.y}%;`}>
              <div class="ig-node-icon" set:html={icons[n.icon]} />
              <span class="ig-node-label">{n.label}</span>
            </div>
          ))}
        </div>

        <div class="ig-banner">
          <span set:html={icons.checkcircle} />
          {tg.s1_banner}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       02 · INTEGRACIONES FLEXIBLES
  ═══════════════════════════════════════════════ -->
  <section class="ig-section ig-bg-b">
    <div class="container ig-grid">
      <div class="ig-text reveal">
        <div class="ig-num-row">
          <span class="ig-num">{tg.s2_num}</span>
          <span class="eyebrow" style="margin:0;">{tg.s2_eyebrow}</span>
        </div>
        <h2>{tg.s2_title1}<br/><em>{tg.s2_title2}</em></h2>
        <p class="section-desc">{tg.s2_desc}</p>
        <ul class="ig-list">
          {s2items.map(item => (
            <li>
              <span class="ig-list-icon" set:html={icons[item.icon]} />
              <span class="ig-list-text"><strong>{item.title}</strong><br/>{item.desc}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="ig-visual reveal reveal-delay-2">
        <span class="ig-protocols-label">{tg.s2_protocols_label}</span>
        <div class="ig-protocols">
          {protocols.map(p => (
            <div class="ig-proto">
              <span class="ig-proto-icon" set:html={icons[p.icon]} />
              <span>{p.label}</span>
            </div>
          ))}
        </div>

        <div class="ig-card">
          <div class="ig-panel-head">
            <span set:html={icons.external} />
            {tg.s2_panel_title}
          </div>
          <div class="ig-panel-body">
            <ul class="ig-panel-nav">
              {navItems.map((n, i) => <li class={i === 0 ? 'active' : ''}>{n}</li>)}
            </ul>
            <div class="ig-panel-table-wrap">
              <div class="ig-panel-table-head">
                <span>{tg.s2_col_connector}</span>
                <span>{tg.s2_col_status}</span>
                <span>{tg.s2_col_sync}</span>
              </div>
              <ul class="ig-panel-table">
                {connectorRows.map(r => (
                  <li>
                    <span class="ig-panel-row-name"><span class="ig-panel-row-icon" set:html={icons[r.icon]} />{r.name}</span>
                    <span class="ig-panel-status">● {tg.s2_status_connected}</span>
                    <span class="ig-panel-sync">{r.sync}</span>
                  </li>
                ))}
              </ul>
              <span class="ig-panel-add">{tg.s2_add}</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       03 · INFORMACIÓN QUE FLUYE
  ═══════════════════════════════════════════════ -->
  <section class="ig-section ig-bg-a">
    <div class="container ig-grid">
      <div class="ig-text reveal">
        <div class="ig-num-row">
          <span class="ig-num">{tg.s3_num}</span>
          <span class="eyebrow" style="margin:0;">{tg.s3_eyebrow}</span>
        </div>
        <h2>{tg.s3_title1}<br/><em>{tg.s3_title2}</em></h2>
        <p class="section-desc">{tg.s3_desc}</p>
        <ul class="ig-list">
          {s3items.map(item => (
            <li>
              <span class="ig-list-icon" set:html={icons[item.icon]} />
              <span class="ig-list-text"><strong>{item.title}</strong><br/>{item.desc}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="ig-visual reveal reveal-delay-2">
        <div class="ig-card ig-funnel">
          <div class="ig-funnel-col">
            <span class="ig-funnel-title">{tg.s3_sources_title}</span>
            <ul class="ig-funnel-list">
              {sources.map(s => <li><span set:html={icons[s.icon]} />{s.label}</li>)}
            </ul>
          </div>

          <div class="ig-funnel-center">
            <span class="ig-funnel-conn ig-funnel-conn--left"></span>
            <div class="ig-hub">
              <span class="ig-hub-logo"><img src="/maindhotel_icono.svg" alt="MaindHotel" /></span>
              <span class="ig-hub-name">{tg.s3_center_name}</span>
              <span class="ig-hub-sub">{tg.s3_center_sub}</span>
            </div>
            <span class="ig-funnel-conn ig-funnel-conn--right"></span>
          </div>

          <div class="ig-funnel-col">
            <span class="ig-funnel-title">{tg.s3_dest_title}</span>
            <ul class="ig-funnel-list">
              {destinations.map(d => <li><span set:html={icons[d.icon]} />{d.label}</li>)}
            </ul>
          </div>
        </div>

        <div class="ig-rules-pill">
          <span set:html={icons.checkcircle} />
          {tg.s3_rules}
        </div>

        <div class="ig-stats-row">
          {stats3.map(s => (
            <div class="ig-stat">
              <span class="ig-stat-icon" set:html={icons[s.icon]} />
              {s.val && <span class="ig-stat-val">{s.val}</span>}
              <span class="ig-stat-label">{s.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       04 · UN EQUIPO, UN OBJETIVO
  ═══════════════════════════════════════════════ -->
  <section class="ig-section ig-bg-b">
    <div class="container">
      <div class="ig-grid">
        <div class="ig-text reveal">
          <div class="ig-num-row">
            <span class="ig-num">{tg.s4_num}</span>
            <span class="eyebrow" style="margin:0;">{tg.s4_eyebrow}</span>
          </div>
          <h2>{tg.s4_title1}<br/><em>{tg.s4_title2}</em></h2>
          <p class="section-desc">{tg.s4_desc}</p>
        </div>

        <div class="ig-visual reveal reveal-delay-2">
          <div class="ig-triflow">
            <div class="ig-tri-node">
              <span class="ig-tri-icon" set:html={icons.database} />
              <strong>{tg.s4_data_label}</strong>
              <span>{tg.s4_data_sub}</span>
            </div>
            <span class="ig-tri-conn"></span>
            <div class="ig-tri-hub">
              <span class="ig-tri-hub-logo"><img src="/maindhotel_icono.svg" alt="MaindHotel" /></span>
              <strong>{tg.s4_center_name}</strong>
              <span>{tg.s4_center_sub}</span>
            </div>
            <span class="ig-tri-conn"></span>
            <div class="ig-tri-node">
              <span class="ig-tri-icon" set:html={icons.users} />
              <strong>{tg.s4_people_label}</strong>
              <span>{tg.s4_people_sub}</span>
            </div>
          </div>
        </div>
      </div>

