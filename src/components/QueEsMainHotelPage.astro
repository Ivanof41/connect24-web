---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
  lang: string;
}
const { t, lang } = Astro.props;
const tq = t.queesmainhotel;

const icons: Record<string, string> = {
  server: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="8" rx="2"/><rect x="2" y="13" width="20" height="8" rx="2"/><line x1="6" y1="7" x2="6.01" y2="7"/><line x1="6" y1="17" x2="6.01" y2="17"/></svg>`,
  wifi: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
  zap: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  droplet: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2s7 8.5 7 13a7 7 0 0 1-14 0c0-4.5 7-13 7-13z"/></svg>`,
  wind: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9.59 4.59A2 2 0 1 1 11 8H2"/><path d="M12.59 19.41A2 2 0 1 0 14 16H2"/><path d="M17.73 7.73A2.5 2.5 0 1 1 19.5 12H2"/></svg>`,
  snow: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="12" y1="2" x2="12" y2="22"/><line x1="4.93" y1="4.93" x2="19.07" y2="19.07"/><line x1="4.93" y1="19.07" x2="19.07" y2="4.93"/><line x1="2" y1="12" x2="22" y2="12"/></svg>`,
  waves: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M2 12s2-3 5-3 5 3 8 3 5-3 5-3"/><path d="M2 17s2-3 5-3 5 3 8 3 5-3 5-3"/></svg>`,
  shieldcheck: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  user: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  wrench: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  clipboard: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M16 4h2a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H6a2 2 0 0 1-2-2V6a2 2 0 0 1 2-2h2"/><rect x="8" y="2" width="8" height="4" rx="1"/></svg>`,
  filetext: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  smile: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><path d="M8 14s1.5 2 4 2 4-2 4-2"/><line x1="9" y1="9" x2="9.01" y2="9"/><line x1="15" y1="9" x2="15.01" y2="9"/></svg>`,
  trending: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  xcircle: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><line x1="15" y1="9" x2="9" y2="15"/><line x1="9" y1="9" x2="15" y2="15"/></svg>`,
  network: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="6" cy="6" r="3"/><circle cx="18" cy="6" r="3"/><circle cx="12" cy="19" r="3"/><line x1="8.5" y1="7.6" x2="10.5" y2="16.5"/><line x1="15.5" y1="7.6" x2="13.5" y2="16.5"/><line x1="9" y1="6" x2="15" y2="6"/></svg>`,
  alert: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  target: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
  building: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="22" x2="10" y2="15"/><line x1="14" y1="22" x2="14" y2="15"/></svg>`,
  grid: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  star: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"/></svg>`,
  users: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
};

const col1 = [tq.s1_col1_1, tq.s1_col1_2, tq.s1_col1_3, tq.s1_col1_4, tq.s1_col1_5, tq.s1_col1_6, tq.s1_col1_7, tq.s1_col1_8];
const col1Icons = ['server', 'wifi', 'zap', 'droplet', 'wind', 'snow', 'waves', 'shieldcheck'];
const col2 = [tq.s1_col2_1, tq.s1_col2_2, tq.s1_col2_3, tq.s1_col2_4, tq.s1_col2_5, tq.s1_col2_6, tq.s1_col2_7, tq.s1_col2_8];
const col2Icons = ['user', 'wrench', 'shieldcheck', 'clipboard', 'bell', 'filetext', 'smile', 'trending'];

const bottomIcons = ['zap', 'droplet', 'wind', 'snow', 'shieldcheck'];

// Hexagonal radial layout for section 04 (6 nodes) — same technique as the
// Conecta 360 hub: the connector line stops at the icon's near edge so it
// never crosses the label beneath it, regardless of the node's position.
const ICON_R = 9;
const rawNodes = [
  { label: tq.s4_node1, x: 50,    y: 8,  icon: 'server' },
  { label: tq.s4_node2, x: 86.37, y: 29, icon: 'wifi' },
  { label: tq.s4_node3, x: 86.37, y: 71, icon: 'grid' },
  { label: tq.s4_node4, x: 50,    y: 92, icon: 'network' },
  { label: tq.s4_node5, x: 13.63, y: 71, icon: 'building' },
  { label: tq.s4_node6, x: 13.63, y: 29, icon: 'wrench' },
];
const nodes = rawNodes.map(n => {
  const dx = n.x - 50, dy = n.y - 50;
  const dist = Math.sqrt(dx * dx + dy * dy);
  const lineX = n.x - (dx / dist) * ICON_R;
  const lineY = n.y - (dy / dist) * ICON_R;
  return { ...n, lineX, lineY };
});

// Demo de metodología (Integración → Análisis → Acción), traída de la home
// (componente ComoFunciona / t.como) para el punto 03.
const tm = t.como;
const flowSources = [
  {
    logo: '/logos/loxone.svg', brand: 'LOXONE',
    device: tm.flow_p1_device, category: tm.flow_p1_cat, catClass: 'qmh-cat-teal',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M12 2.69l5.66 5.66a8 8 0 1 1-11.31 0z"/></svg>`,
  },
  {
    logo: '/logos/lorawan.svg', brand: 'LoRaWAN',
    device: tm.flow_p2_device, category: tm.flow_p2_cat, catClass: 'qmh-cat-amber',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><line x1="12" y1="2" x2="12" y2="22"/><line x1="2" y1="12" x2="22" y2="12"/><polyline points="17 7 12 2 7 7"/><polyline points="17 17 12 22 7 17"/><polyline points="7 7 2 12 7 17"/><polyline points="17 7 22 12 17 17"/></svg>`,
  },
  {
    logo: '/logos/huawei.svg', brand: 'HUAWEI',
    device: tm.flow_p3_device, category: tm.flow_p3_cat, catClass: 'qmh-cat-green',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  },
  {
    logo: '/logos/knx.svg', brand: 'KNX',
    device: tm.flow_p4_device, category: tm.flow_p4_cat, catClass: 'qmh-cat-red',
    icon: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" width="20" height="20"><path d="M14 14.76V3.5a2.5 2.5 0 0 0-5 0v11.26a4.5 4.5 0 1 0 5 0z"/></svg>`,
  },
];
const CARD_DURATION = 4;
const CYCLE_DURATION = flowSources.length * CARD_DURATION;

const benefits = [
  { title: tq.benefit1_title, desc: tq.benefit1_desc, icon: 'star' },
  { title: tq.benefit2_title, desc: tq.benefit2_desc, icon: 'trending' },
  { title: tq.benefit3_title, desc: tq.benefit3_desc, icon: 'users' },
  { title: tq.benefit4_title, desc: tq.benefit4_desc, icon: 'trending' },
];
---
<Layout title={tq.page_title} description={tq.page_desc}>
  <Nav t={t.nav} lang={lang} />

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="qmh-hero">
    <div class="container qmh-hero-inner reveal">
      <span class="qmh-eyebrow-badge">{tq.hero_eyebrow}</span>
      <h1 class="qmh-hero-title">{tq.hero_title}</h1>
      <p class="qmh-hero-sub">{tq.hero_sub}</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       01 · EL PROBLEMA
  ═══════════════════════════════════════════════ -->
  <section class="qmh-section qmh-bg-a">
    <div class="container">
      <div class="qmh-intro reveal">
        <div class="qmh-num-row">
          <span class="qmh-num">{tq.s1_num}</span>
          <span class="eyebrow" style="margin:0;">{tq.s1_eyebrow}</span>
        </div>
        <h2>{tq.s1_title1}<br/>{tq.s1_title2}</h2>
        <p class="section-desc" style="margin-bottom:1.25rem;">{tq.s1_desc}</p>
        <div class="qmh-note qmh-note--warn">
          <span class="qmh-note-icon" set:html={icons.alert} />
          {tq.s1_note}
        </div>
      </div>

      <div class="qmh-problem-row reveal reveal-delay-2">
        <div class="qmh-problem-card">
          <span class="qmh-problem-title">{tq.s1_col1_title}</span>
          <ul class="qmh-problem-list">
            {col1.map((label, i) => (
              <li><span class="qmh-problem-icon" set:html={icons[col1Icons[i]]} />{label}</li>
            ))}
          </ul>
        </div>

        <div class="qmh-broken-col">
          <span class="qmh-conn-line"></span>
          <div class="qmh-broken-badge" set:html={icons.xcircle} />
          <span class="qmh-conn-line"></span>
          <span class="qmh-broken-label">{tq.s1_broken_label}</span>
        </div>

        <div class="qmh-problem-card">
          <span class="qmh-problem-title">{tq.s1_col2_title}</span>
          <ul class="qmh-problem-list">
            {col2.map((label, i) => (
              <li><span class="qmh-problem-icon" set:html={icons[col2Icons[i]]} />{label}</li>
            ))}
          </ul>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       02 · QUÉ ES MAINHOTEL
  ═══════════════════════════════════════════════ -->
  <section class="qmh-section qmh-bg-b">
    <div class="container qmh-grid">
      <div class="qmh-text reveal">
        <div class="qmh-num-row">
          <span class="qmh-num">{tq.s2_num}</span>
          <span class="eyebrow" style="margin:0;">{tq.s2_eyebrow}</span>
        </div>
        <h2>{tq.s2_title1}<br/><em>{tq.s2_title2}</em></h2>
        <p class="section-desc">{tq.s2_desc}</p>
      </div>

      <div class="qmh-visual reveal reveal-delay-2">
        <div class="qmh-stack">
          <div class="qmh-stack-box">
            <span class="qmh-stack-icon" set:html={icons.users} />
            <div class="qmh-stack-text">
              <strong>{tq.s2_top_title}</strong>
              <span>{tq.s2_top_sub}</span>
            </div>
          </div>

          <div class="qmh-vconn">
            <span class="qmh-vconn-arrow qmh-vconn-arrow--up"></span>
            <span class="qmh-vconn-dot"></span>
            <span class="qmh-vconn-arrow qmh-vconn-arrow--down"></span>
          </div>

          <div class="qmh-stack-hub">
            <img class="qmh-hub-logo" src="/maindhotel_icono.svg" alt="MaindHotel" />
            <div class="qmh-stack-text">
              <strong>{tq.s2_mid_title}</strong>
              <span class="qmh-hub-sub">{tq.s2_mid_sub}</span>
              <span class="qmh-hub-tags">{tq.s2_mid_tags}</span>
            </div>
          </div>

          <div class="qmh-vconn">
            <span class="qmh-vconn-arrow qmh-vconn-arrow--up"></span>
            <span class="qmh-vconn-dot" style="animation-delay:1s"></span>
            <span class="qmh-vconn-arrow qmh-vconn-arrow--down"></span>
          </div>

          <div class="qmh-stack-box">
            <span class="qmh-stack-icon" set:html={icons.server} />
            <div class="qmh-stack-text">
              <strong>{tq.s2_bottom_title}</strong>
              <span>{tq.s2_bottom_sub}</span>
            </div>
          </div>

          <div class="qmh-stack-icons">
            {bottomIcons.map(ic => <span set:html={icons[ic]} />)}
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       03 · QUÉ HACE ESTA CAPA
  ═══════════════════════════════════════════════ -->
  <section class="qmh-section qmh-bg-a">
    <div class="container">
      <div class="qmh-intro reveal" style="margin-bottom: 3.5rem;">
        <div class="qmh-num-row">
          <span class="qmh-num">{tq.s3_num}</span>
          <span class="eyebrow" style="margin:0;">{tq.s3_eyebrow}</span>
        </div>
        <h2>{tq.s3_title1} <em>{tq.s3_title2}</em></h2>
      </div>

      <div class="qmh-flow-card reveal reveal-delay-1">
        <div class="qmh-flow-grid">

          <div class="qmh-flow-step">
            <div class="qmh-flow-num qmh-flow-num--1">01</div>
            <span class="qmh-flow-label">{tm.step1_label}</span>
            <p>{tm.step1_desc}</p>
          </div>
          <div class="qmh-fhconn qmh-fhconn--teal"><span class="qmh-fconn-bar"><span class="qmh-fconn-particle"></span></span></div>
          <div class="qmh-flow-step">
            <div class="qmh-flow-num qmh-flow-num--2">02</div>
            <span class="qmh-flow-label">{tm.step2_label}</span>
            <p>{tm.step2_desc}</p>
          </div>
          <div class="qmh-fhconn qmh-fhconn--teal"><span class="qmh-fconn-bar"><span class="qmh-fconn-particle"></span></span></div>
          <div class="qmh-flow-step">
            <div class="qmh-flow-num qmh-flow-num--3">03</div>
            <span class="qmh-flow-label">{tm.step3_label}</span>
            <p>{tm.step3_desc}</p>
          </div>

          <div class="qmh-fvconn"><span class="qmh-fvbar"><span class="qmh-fvparticle"></span></span></div>
          <div></div>
          <div class="qmh-fvconn"><span class="qmh-fvbar"><span class="qmh-fvparticle"></span></span></div>
          <div></div>
          <div class="qmh-fvconn"><span class="qmh-fvbar"><span class="qmh-fvparticle"></span></span></div>

          <div class="qmh-flow-sources">
            {flowSources.map((p, i) => (
              <div class="qmh-proto-card" style={`animation-delay: ${i * CARD_DURATION}s; animation-duration: ${CYCLE_DURATION}s`}>
                <div class="qmh-proto-header">
                  <img src={p.logo} alt={p.brand} class="qmh-proto-logo" />
                  <span class="qmh-online-badge"><span class="qmh-online-dot"></span>Online</span>
                </div>
                <div class="qmh-proto-device">
                  <div class="qmh-device-icon" set:html={p.icon} />
                  <div class="qmh-device-info">
                    <span class="qmh-device-name">{p.device}</span>
                    <span class={`qmh-device-cat ${p.catClass}`}>{p.category}</span>
                  </div>
                </div>
              </div>
            ))}
          </div>

          <div class="qmh-fhconn qmh-fhconn--red"><span class="qmh-fconn-bar"><span class="qmh-fconn-particle"></span></span></div>

          <div class="qmh-flow-center">
            <div class="qmh-processor-card">
              <img src="/ConnectIA.svg" alt="connectIA" class="qmh-c24-logo" />
              <div class="qmh-analysis-progress"><div class="qmh-progress-fill"></div></div>
              <div class="qmh-proc-text-wrap">
                <span class="qmh-proc-text qmh-proc-text--analyzing">{tm.flow_analyzing}</span>
                <span class="qmh-proc-text qmh-proc-text--done">{tm.flow_processing}</span>
              </div>
            </div>
          </div>

          <div class="qmh-fhconn qmh-fhconn--green"><span class="qmh-fconn-bar"><span class="qmh-fconn-particle"></span></span></div>

          <div class="qmh-flow-result">
            <div class="qmh-result-card">
              <div class="qmh-result-check-wrap">
                <div class="qmh-ripple qmh-ripple-1"></div>
                <div class="qmh-ripple qmh-ripple-2"></div>
                <div class="qmh-result-check">
                  <svg viewBox="0 0 24 24" fill="none" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" width="26" height="26">
                    <polyline class="qmh-check-stroke" points="20 6 9 17 4 12"/>
                  </svg>
                </div>
              </div>
              <span class="qmh-result-label">{tm.flow_completed}</span>
              <div class="qmh-result-stats">
                <span class="qmh-result-stat">{tm.flow_stat1}</span>
                <span class="qmh-result-stat">{tm.flow_stat2}</span>
                <span class="qmh-result-stat">{tm.flow_stat3}</span>
              </div>
            </div>
          </div>

        </div>
      </div>

      <div class="qmh-note qmh-note--accent reveal reveal-delay-2">
        <span class="qmh-note-icon" set:html={icons.target} />
        {tq.s3_note}
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       04 · CÓMO JUEGA EN EQUIPO
  ═══════════════════════════════════════════════ -->
  <section class="qmh-section qmh-bg-b">
    <div class="container">
      <div class="qmh-grid">
        <div class="qmh-text reveal">
          <div class="qmh-num-row">
            <span class="qmh-num">{tq.s4_num}</span>
            <span class="eyebrow" style="margin:0;">{tq.s4_eyebrow}</span>
          </div>
          <h2>{tq.s4_title1}<br/><em>{tq.s4_title2}</em></h2>
          <p class="section-desc">{tq.s4_desc}</p>
        </div>

        <div class="qmh-visual reveal reveal-delay-2">
          <div class="qmh-radial">
