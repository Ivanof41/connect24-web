.qmh-online-badge { display: flex; align-items: center; gap: 0.3rem; font-size: 0.68rem; font-weight: 700; color: #22c55e; letter-spacing: 0.03em; }
.qmh-online-dot { width: 7px; height: 7px; border-radius: 50%; background: #22c55e; animation: qmhPulseDot 2s ease-in-out infinite; }
@keyframes qmhPulseDot { 0%, 100% { box-shadow: 0 0 0 0 rgba(34,197,94,0.5); } 50% { box-shadow: 0 0 0 4px rgba(34,197,94,0); } }
.qmh-proto-device { display: flex; align-items: center; gap: 0.75rem; }
.qmh-device-icon { display: flex; align-items: center; justify-content: center; width: 36px; height: 36px; border-radius: 50%; background: var(--c24-teal-light); color: var(--c24-teal); flex-shrink: 0; }
:global([data-theme="dark"]) .qmh-device-icon { background: rgba(106,181,171,0.14); }
.qmh-device-info { display: flex; flex-direction: column; gap: 0.2rem; }
