.qmh-device-cat { font-size: 0.68rem; font-weight: 700; letter-spacing: 0.08em; text-transform: uppercase; }
.qmh-cat-teal  { color: var(--c24-teal); }
.qmh-cat-amber { color: #f59e0b; }
.qmh-cat-green { color: #22c55e; }
.qmh-cat-red   { color: #ef4444; }

/* Processor card (row 3, col 3) */
.qmh-flow-center { justify-self: center; align-self: center; }
.qmh-processor-card { display: flex; flex-direction: column; align-items: center; gap: 0.875rem; width: 150px; }
.qmh-c24-logo { height: 64px; width: auto; object-fit: contain; }
:global([data-theme="dark"]) .qmh-c24-logo { filter: brightness(0) invert(1); }
.qmh-analysis-progress { width: 90px; height: 5px; background: rgba(106,181,171,0.18); border-radius: 5px; overflow: hidden; }
.qmh-progress-fill { height: 100%; width: 0%; background: var(--c24-teal); border-radius: 5px; animation: qmhFillProgress 6s ease-in-out infinite; }
@keyframes qmhFillProgress {
  0%   { width: 0%;   opacity: 1; }
  62%  { width: 100%; opacity: 1; }
  78%  { width: 100%; opacity: 1; }
  90%  { width: 100%; opacity: 0; }
  100% { width: 0%;   opacity: 0; }
}
.qmh-proc-text-wrap { position: relative; height: 1.1rem; width: 100%; text-align: center; }
.qmh-proc-text { position: absolute; inset: 0; display: flex; align-items: center; justify-content: center; font-size: 0.68rem; font-weight: 700; color: var(--c24-teal); letter-spacing: 0.06em; white-space: nowrap; }
.qmh-proc-text--analyzing { animation: qmhTextAnalyzing 6s ease-in-out infinite; }
@keyframes qmhTextAnalyzing { 0% { opacity: 1; } 58% { opacity: 1; } 68% { opacity: 0; } 100% { opacity: 0; } }
.qmh-proc-text--done { opacity: 0; animation: qmhTextDone 6s ease-in-out infinite; }
@keyframes qmhTextDone { 0% { opacity: 0; } 65% { opacity: 0; } 73% { opacity: 1; } 82% { opacity: 1; } 90% { opacity: 0; } 100% { opacity: 0; } }

/* Result card (row 3, col 5) */
.qmh-flow-result { justify-self: center; align-self: center; }
.qmh-result-card { display: flex; flex-direction: column; align-items: center; gap: 0.75rem; width: 168px; }
.qmh-result-check-wrap { position: relative; display: flex; align-items: center; justify-content: center; width: 52px; height: 52px; margin-bottom: 1.75rem; }
.qmh-ripple { position: absolute; inset: 0; border-radius: 50%; border: 2px solid #22c55e; animation: qmhRippleOut 2.4s ease-out infinite; }
.qmh-ripple-2 { animation-delay: 1.2s; }
@keyframes qmhRippleOut { 0% { transform: scale(1); opacity: 0.55; } 100% { transform: scale(2.4); opacity: 0; } }
.qmh-result-check { position: relative; width: 52px; height: 52px; border-radius: 50%; background: #22c55e; display: flex; align-items: center; justify-content: center; }
.qmh-check-stroke { stroke-dasharray: 30; stroke-dashoffset: 30; animation: qmhDrawCheck 4s ease-in-out infinite; }
@keyframes qmhDrawCheck { 0% { stroke-dashoffset: 30; } 15% { stroke-dashoffset: 0; } 85% { stroke-dashoffset: 0; } 100% { stroke-dashoffset: 30; } }
.qmh-result-label { font-size: 0.78rem; font-weight: 700; color: var(--c24-text); text-align: center; letter-spacing: 0.02em; line-height: 1.4; }
.qmh-result-stats { position: relative; height: 1rem; width: 100%; overflow: hidden; }
.qmh-result-stat {
  position: absolute; inset: 0; display: flex; align-items: center; justify-content: center;
  font-size: 0.65rem; font-weight: 600; color: #22c55e; letter-spacing: 0.03em; opacity: 0; white-space: nowrap;
  animation: qmhStatCycle 6s ease-in-out infinite both;
}
.qmh-result-stat:nth-child(2) { animation-delay: 2s; }
.qmh-result-stat:nth-child(3) { animation-delay: 4s; }
@keyframes qmhStatCycle {
  0%   { opacity: 0; transform: translateY(6px); }
  8%   { opacity: 1; transform: translateY(0); }
  28%  { opacity: 1; transform: translateY(0); }
  36%  { opacity: 0; transform: translateY(-6px); }
  100% { opacity: 0; }
}

/* ═══════════════════════════════════════════════
   04 · RADIAL + BENEFITS
