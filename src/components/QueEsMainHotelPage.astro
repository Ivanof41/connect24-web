.qmh-flow-step p { font-size: 0.85rem; color: var(--c24-text-muted); line-height: 1.65; font-weight: 300; }

/* Horizontal connectors (rows 1 and 3) */
.qmh-fhconn { display: flex; align-items: center; min-width: 60px; align-self: center; justify-self: stretch; position: relative; }
.qmh-fconn-bar { flex: 1; height: 3px; border-radius: 3px; position: relative; overflow: hidden; margin-right: 7px; }
.qmh-fhconn::after {
  content: ''; position: absolute; right: 0; top: 50%; transform: translateY(-50%);
  width: 0; height: 0; border-top: 5px solid transparent; border-bottom: 5px solid transparent;
}
.qmh-fhconn--teal .qmh-fconn-bar  { background: rgba(106,181,171,0.18); }
.qmh-fhconn--red .qmh-fconn-bar   { background: rgba(239,68,68,0.18); }
.qmh-fhconn--green .qmh-fconn-bar { background: rgba(106,181,171,0.18); }
.qmh-fhconn--teal::after  { border-left: 8px solid rgba(106,181,171,0.55); }
.qmh-fhconn--red::after   { border-left: 8px solid #ef4444; }
.qmh-fhconn--green::after { border-left: 8px solid var(--c24-teal); }
.qmh-fconn-particle { position: absolute; top: 0; left: -50%; width: 50%; height: 100%; border-radius: 3px; }
.qmh-fhconn--teal .qmh-fconn-particle {
  background: linear-gradient(90deg, transparent, var(--c24-teal), transparent); animation: qmhConnFlow 1.8s linear infinite;
}
.qmh-fhconn--red .qmh-fconn-particle {
  background: linear-gradient(90deg, transparent, #ef4444, transparent); animation: qmhConnFlow 1.5s linear infinite;
}
.qmh-fhconn--green .qmh-fconn-particle {
  background: linear-gradient(90deg, transparent, var(--c24-teal), transparent); animation: qmhConnFlow 1.5s linear infinite 0.75s;
}
@keyframes qmhConnFlow { from { left: -50%; } to { left: 110%; } }

