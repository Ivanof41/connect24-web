---
interface Props {
  t: {
    eyebrow: string;
    title1: string;
    title2: string;
    desc: string;
    btn1: string;
    btn2: string;
    note: string;
  };
}
const { t } = Astro.props;
---

<section class="cta-final">
  <div class="cta-bg"></div>
  <div class="container cta-inner">

    <div class="reveal">
      <span class="eyebrow" style="color:var(--c24-teal)">{t.eyebrow}</span>
      <h2>{t.title1}<br/><em>{t.title2}</em></h2>
      <p class="cta-sub">{t.desc}</p>
      <div class="cta-actions">
        <button class="btn btn-primary cta-btn" id="ctaFinalBtn">
          {t.btn1}
        </button>
        <a
          href="https://go.connect24.io"
          target="_blank"
          rel="noopener"
          class="btn btn-ghost cta-btn-ghost"
        >
          {t.btn2}
        </a>
      </div>
      <p class="cta-note">{t.note}</p>
    </div>

  </div>
</section>

<style>
  .cta-final {
    padding: 8rem 2rem;
    background: var(--c24-navy);
    position: relative;
    overflow: hidden;
    text-align: center;
  }

  .cta-bg {
    position: absolute; inset: 0; pointer-events: none;
    background:
      radial-gradient(ellipse 60% 60% at 50% 100%, rgba(69,191,162,0.12) 0%, transparent 70%),
      radial-gradient(ellipse 40% 40% at 50% 0%, rgba(69,191,162,0.06) 0%, transparent 60%);
  }

  .cta-inner {
    position: relative; z-index: 1;
    max-width: 680px;
  }

  h2 { color: white; margin-bottom: 1.25rem; }
  h2 em { font-style: italic; color: var(--c24-teal); }

  .cta-sub {
    font-size: 1rem;
    color: rgba(255,255,255,0.55);
    line-height: 1.8; font-weight: 300;
    max-width: 480px;
    margin: 0 auto 2.5rem;
  }

  .cta-actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 1rem; flex-wrap: wrap;
    margin-bottom: 1.5rem;
  }

  .cta-btn-ghost {
    border-color: rgba(255,255,255,0.2);
    color: rgba(255,255,255,0.7);
  }
  .cta-btn-ghost:hover {
    border-color: var(--c24-teal);
    color: var(--c24-teal);
  }

  .cta-note {
    font-size: 0.78rem;
    color: rgba(255,255,255,0.3);
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .cta-final { padding: 5rem 1.5rem; }
    .cta-actions { flex-direction: column; align-items: stretch; }
    .cta-actions .btn { justify-content: center; }
  }
</style>

<script>
  document.getElementById('ctaFinalBtn')?.addEventListener('click', () => {
    document.getElementById('modal')?.classList.add('active');
    document.body.style.overflow = 'hidden';
  });
</script>