---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import CtaFinal from './CtaFinal.astro';
import Modal from './Modal.astro';
import Footer from './Footer.astro';
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
  lang: string;
}
const { t, lang } = Astro.props;
const h = t.home;

const icons: Record<string, string> = {
  brain: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 2a4 4 0 0 0-4 4v.5A3.5 3.5 0 0 0 5 10a3.5 3.5 0 0 0 1 6.9A3.5 3.5 0 0 0 9.5 21a3.5 3.5 0 0 0 2.5-1.05A3.5 3.5 0 0 0 14.5 21a3.5 3.5 0 0 0 3.5-4.1A3.5 3.5 0 0 0 19 10a3.5 3.5 0 0 0-3-3.5V6a4 4 0 0 0-4-4z"/><line x1="12" y1="6" x2="12" y2="19"/></svg>`,
  trending: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  shieldcheck: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  users: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>`,
  monitor: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  building: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="4" y="2" width="16" height="20" rx="1"/><line x1="4" y1="9" x2="20" y2="9"/><line x1="4" y1="15" x2="20" y2="15"/><line x1="10" y1="22" x2="10" y2="15"/><line x1="14" y1="22" x2="14" y2="15"/></svg>`,
  wifi: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
  zap: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
  cpu: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="1"/><path d="M9 1v4M15 1v4M9 19v4M15 19v4M1 9h4M1 15h4M19 9h4M19 15h4"/></svg>`,
  checkcircle: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"/><polyline points="22 4 12 14.01 9 11.01"/></svg>`,
  server: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="8" rx="2"/><rect x="2" y="13" width="20" height="8" rx="2"/><line x1="6" y1="7" x2="6.01" y2="7"/><line x1="6" y1="17" x2="6.01" y2="17"/></svg>`,
  euro: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 7.5a6.5 6.5 0 1 0 0 9"/><line x1="3.5" y1="10" x2="13.5" y2="10"/><line x1="3.5" y1="14" x2="12" y2="14"/></svg>`,
  wrench: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  cloud: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h.79a4.5 4.5 0 1 1 0 9z"/></svg>`,
  building2: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  more: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg>`,
  settings: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  filetext: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
};

const s1Stats = [
  { icon: 'brain', label: h.s1_stat1 },
  { icon: 'trending', label: h.s1_stat2 },
  { icon: 'shieldcheck', label: h.s1_stat3 },
  { icon: 'users', label: h.s1_stat4 },
];

const s2Items = [h.s2_item1, h.s2_item2, h.s2_item3, h.s2_item4];
const s2Stats = [
  { label: h.s2_stat1_label, val: h.s2_stat1_val },
  { label: h.s2_stat2_label, val: h.s2_stat2_val },
  { label: h.s2_stat3_label, val: h.s2_stat3_val, note: h.s2_stat3_note },
  { label: h.s2_stat4_label, val: h.s2_stat4_val },
];
const s2Incidents = [
  { title: h.s2_inc1_title, loc: h.s2_inc1_loc, sev: h.s2_inc1_sev, sevClass: 'h-sev-critical', time: h.s2_inc1_time },
  { title: h.s2_inc2_title, loc: h.s2_inc2_loc, sev: h.s2_inc2_sev, sevClass: 'h-sev-important', time: h.s2_inc2_time },
  { title: h.s2_inc3_title, loc: h.s2_inc3_loc, sev: h.s2_inc3_sev, sevClass: 'h-sev-moderate', time: h.s2_inc3_time },
];
const energyBars = [45, 60, 38, 72, 55, 68, 82, 50, 63, 78, 58, 90];

const s3items = [
  { title: h.s3_item1_title, desc: h.s3_item1_desc, icon: 'brain' },
  { title: h.s3_item2_title, desc: h.s3_item2_desc, icon: 'zap' },
  { title: h.s3_item3_title, desc: h.s3_item3_desc, icon: 'shieldcheck' },
  { title: h.s3_item4_title, desc: h.s3_item4_desc, icon: 'trending' },
];
// Four-step cycle: top → right → bottom → left → top, each arc bowing outward.
// Nodes sit at 16%/84% (not 12%/88%) so the fixed-size labels never clip
// past the container edge on narrow viewports.
const cycleSteps = [
  { title: h.s3_step1_title, sub: h.s3_step1_sub, icon: 'brain',       x: 50, y: 16 },
  { title: h.s3_step2_title, sub: h.s3_step2_sub, icon: 'zap',         x: 84, y: 50 },
  { title: h.s3_step3_title, sub: h.s3_step3_sub, icon: 'checkcircle', x: 50, y: 84 },
  { title: h.s3_step4_title, sub: h.s3_step4_sub, icon: 'trending',    x: 16, y: 50 },
];
const cycleArcs = [
  'M50,16 Q84,16 84,50',
  'M84,50 Q84,84 50,84',
  'M50,84 Q16,84 16,50',
  'M16,50 Q16,16 50,16',
];

const protocols = [
  { label: h.s4_p1, icon: 'server' },
  { label: h.s4_p2, icon: 'building' },
  { label: h.s4_p3, icon: 'wifi' },
  { label: h.s4_p4, icon: 'wrench' },
  { label: h.s4_p5, icon: 'euro' },
  { label: h.s4_p6, icon: 'cloud' },
  { label: h.s4_p7, icon: 'building2' },
  { label: h.s4_p8, icon: 'more' },
];
const s4Benefits = [
  { label: h.s4_benefit1, icon: 'settings' },
  { label: h.s4_benefit2, icon: 'checkcircle' },
  { label: h.s4_benefit3, icon: 'filetext' },
  { label: h.s4_benefit4, icon: 'trending' },
];
---
<Layout title={h.page_title} description={h.page_desc}>
  <Nav t={t.nav} lang={lang} />

  <!-- ═══════════════════════════════════════════════
       01 · HERO — Inteligencia que conecta instalaciones y operaciones
  ═══════════════════════════════════════════════ -->
  <section class="h-hero">
    <div class="container h-hero-inner">
      <div class="h-hero-text reveal">
        <h1 class="h-hero-title">
          {h.s1_title_pre} <em>{h.s1_title_accent}</em> {h.s1_title_post}
        </h1>
        <p class="h-hero-sub">{h.s1_desc}</p>
        <div class="h-hero-stats">
          {s1Stats.map(s => (
            <div class="h-hero-stat">
              <span class="h-hero-stat-icon" set:html={icons[s.icon]} />
              <span>{s.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="h-stack reveal reveal-delay-2" aria-hidden="true">
        <div class="h-layer">
          <div class="h-layer-icons">
            <span set:html={icons.monitor} /><span set:html={icons.users} /><span set:html={icons.trending} />
          </div>
          <strong>{h.s1_top_title}</strong>
          <span>{h.s1_top_sub}</span>
        </div>

        <div class="h-vconn"><span class="h-vdot"></span></div>

        <div class="h-hub">
          <span class="h-hub-icon"><img src="/connect24_mark_white.png" alt="" /></span>
          <strong>{h.s1_hub_name}</strong>
          <span class="h-hub-sub">{h.s1_hub_sub}</span>
          <span class="h-hub-tags">{h.s1_hub_tags}</span>
        </div>

        <div class="h-vconn"><span class="h-vdot" style="animation-delay:1.1s"></span></div>

        <div class="h-layer">
          <div class="h-layer-icons">
            <span set:html={icons.building} /><span set:html={icons.wifi} /><span set:html={icons.zap} />
          </div>
          <strong>{h.s1_bottom_title}</strong>
          <span>{h.s1_bottom_sub}</span>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       01 · UNA PLATAFORMA, TODO EL CONTROL
  ═══════════════════════════════════════════════ -->
  <section class="h-section h-bg-a">
    <div class="container h-grid">
      <div class="h-text reveal">
        <div class="h-brand">
          <img src="/Oficial_Horizontal.png" alt="Connect24" class="h-brand-light" />
          <img src="/Oficial_Horizontal_INV.png" alt="Connect24" class="h-brand-dark" />
        </div>
        <div class="h-num-row">
          <span class="h-num">{h.s2_num}</span>
          <span class="eyebrow" style="margin:0;">{h.s2_eyebrow}</span>
        </div>
        <h2>{h.s2_title1}<br/><em>{h.s2_title2}</em></h2>
        <p class="section-desc">{h.s2_desc}</p>
        <ul class="h-checklist">
          {s2Items.map(item => <li><span class="h-check">✓</span>{item}</li>)}
        </ul>
      </div>

      <div class="h-visual reveal reveal-delay-2">
        <div class="h-card h-dash">
          <span class="h-card-title">{h.s2_dash_title}</span>
          <div class="h-dash-stats">
            {s2Stats.map(s => (
              <div class="h-mini-stat">
                <span>{s.label}</span>
                <strong>{s.val}</strong>
                {s.note && <em>{s.note}</em>}
              </div>
            ))}
          </div>
          <div class="h-dash-charts">
            <div class="h-chart-box">
              <span class="h-chart-label">{h.s2_energy_label}</span>
              <span class="h-chart-val">{h.s2_energy_val} <small>{h.s2_energy_unit}</small> <em class="h-chart-delta">{h.s2_energy_delta}</em></span>
              <div class="h-bars">
                {energyBars.map(v => <div class="h-bar" style={`height:${v}%`}></div>)}
              </div>
            </div>
            <div class="h-chart-box">
              <span class="h-chart-label">{h.s2_temp_label}</span>
              <span class="h-chart-val">{h.s2_temp_val} <small>{h.s2_temp_unit}</small> <em class="h-chart-delta">{h.s2_temp_delta}</em></span>
              <svg class="h-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
                <polyline points="0,20 10,15 20,18 30,10 40,14 50,8 60,12 70,6 80,10 90,4 100,9" fill="none" stroke="var(--c24-teal)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
          </div>
          <div class="h-incidents">
            <span class="h-chart-label">{h.s2_incidents_label}</span>
            <ul>
              {s2Incidents.map(inc => (
                <li>
                  <div class="h-inc-text">
                    <strong>{inc.title}</strong>
                    <span>{inc.loc}</span>
                  </div>
                  <span class={`h-sev ${inc.sevClass}`}>{inc.sev}</span>
                  <span class="h-inc-time">{inc.time}</span>
                </li>
              ))}
            </ul>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       02 · INTELIGENCIA OPERATIVA QUE GENERA VALOR
  ═══════════════════════════════════════════════ -->
  <section class="h-section h-bg-b">
    <div class="container h-grid">
      <div class="h-text reveal">
        <div class="h-brand">
          <img src="/Oficial_Horizontal.png" alt="Connect24" class="h-brand-light" />
          <img src="/Oficial_Horizontal_INV.png" alt="Connect24" class="h-brand-dark" />
        </div>
        <div class="h-num-row">
          <span class="h-num">{h.s3_num}</span>
          <span class="eyebrow" style="margin:0;">{h.s3_eyebrow}</span>
        </div>
        <h2>{h.s3_title1}<br/><em>{h.s3_title2}</em></h2>
        <p class="section-desc">{h.s3_desc}</p>
        <ul class="h-list">
          {s3items.map(item => (
            <li>
              <span class="h-list-icon" set:html={icons[item.icon]} />
              <span class="h-list-text"><strong>{item.title}</strong><br/>{item.desc}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="h-visual reveal reveal-delay-2">
        <div class="h-cycle">
          <svg class="h-cycle-conn" viewBox="0 0 100 100" preserveAspectRatio="none">
            {cycleArcs.map((d, i) => (
              <path class={`h-cl h-cl${i}`} d={d} fill="none" stroke="currentColor" stroke-width="0.7" stroke-dasharray="2.4 2.4"/>
            ))}
          </svg>
          <div class="h-cycle-hub">
            <img src="/connect24_mark_teal.png" alt="" />
          </div>
          {cycleSteps.map(s => (
            <div class="h-cycle-node" style={`left:${s.x}%; top:${s.y}%;`}>
              <span class="h-cycle-icon" set:html={icons[s.icon]} />
              <strong>{s.title}</strong>
              <span>{s.sub}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       03 · CONECTAMOS SISTEMAS. ALINEAMOS EQUIPOS.
  ═══════════════════════════════════════════════ -->
  <section class="h-section h-bg-a">
    <div class="container h-grid">
      <div class="h-text reveal">
        <div class="h-brand">
          <img src="/Oficial_Horizontal.png" alt="Connect24" class="h-brand-light" />
          <img src="/Oficial_Horizontal_INV.png" alt="Connect24" class="h-brand-dark" />
        </div>
        <div class="h-num-row">
          <span class="h-num">{h.s4_num}</span>
          <span class="eyebrow" style="margin:0;">{h.s4_eyebrow}</span>
        </div>
        <h2>{h.s4_title1}<br/>{h.s4_title2}<br/><em>{h.s4_title3}</em></h2>
        <p class="section-desc">{h.s4_desc}</p>
        <div class="h-protocols">
          {protocols.map(p => (
            <div class="h-proto">
              <span set:html={icons[p.icon]} />
              <span>{p.label}</span>
            </div>
          ))}
        </div>
      </div>

      <div class="h-visual reveal reveal-delay-2">
        <div class="h-triflow">
          <div class="h-tri-node">
            <span class="h-tri-icon" set:html={icons.server} />
            <strong>{h.s4_data_label}</strong>
          </div>
          <span class="h-tri-conn"></span>
          <div class="h-tri-hub">
            <span class="h-tri-hub-icon"><img src="/connect24_mark_teal.png" alt="" /></span>
            <strong>{h.s4_hub_name}</strong>
          </div>
          <span class="h-tri-conn"></span>
          <div class="h-tri-node">
            <span class="h-tri-icon" set:html={icons.users} />
            <strong>{h.s4_people_label}</strong>
          </div>
        </div>
      </div>
    </div>

    <div class="container">
      <div class="h-benefits reveal reveal-delay-3">
        {s4Benefits.map(b => (
          <div class="h-benefit">
            <span class="h-benefit-icon" set:html={icons[b.icon]} />
            <span>{b.label}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <CtaFinal t={t.cta} />
  <Modal t={t.modal} t_calc={t.calculadora} />

  <Footer t={t.footer} />
</Layout>

<style>
/* ═══════════════════════════════════════════════
   01 · HERO
═══════════════════════════════════════════════ */
.h-hero {
  padding: 9rem 2rem 6rem;
  background: linear-gradient(160deg, #005070 0%, #003C5B 50%, #002236 100%);
  position: relative; overflow: hidden;
}
.h-hero::before {
  content: ''; position: absolute; inset: 0; pointer-events: none;
  background:
    radial-gradient(ellipse 50% 60% at 78% 30%, rgba(106,181,171,0.16) 0%, transparent 70%),
    radial-gradient(ellipse 40% 50% at 15% 80%, rgba(106,181,171,0.08) 0%, transparent 65%);
}
.h-hero-inner {
  position: relative; z-index: 1;
  display: grid; grid-template-columns: 1.05fr 0.85fr; gap: 4rem; align-items: center;
}
.h-hero-title {
  font-family: var(--font-display); font-size: clamp(2.2rem, 3.8vw, 3.1rem);
  font-weight: 700; line-height: 1.22; letter-spacing: -0.02em; color: white; margin-bottom: 1.25rem;
}
.h-hero-title em { font-style: normal; color: var(--c24-teal); }
.h-hero-sub { font-size: 1.02rem; color: rgba(255,255,255,0.6); font-weight: 300; line-height: 1.75; max-width: 460px; margin-bottom: 2.25rem; }
.h-hero-stats { display: grid; grid-template-columns: 1fr 1fr; gap: 1.1rem 1.5rem; max-width: 440px; }
.h-hero-stat { display: flex; align-items: center; gap: 0.65rem; font-size: 0.82rem; font-weight: 600; color: rgba(255,255,255,0.85); line-height: 1.3; }
.h-hero-stat-icon {
  flex-shrink: 0; width: 2rem; height: 2rem; border-radius: 8px;
  background: rgba(106,181,171,0.14); color: var(--c24-teal);
  display: flex; align-items: center; justify-content: center;
}
.h-hero-stat-icon :global(svg) { width: 1rem; height: 1rem; }

/* ── Flat stacked-card visual, sized to match the text column height ── */
.h-stack { display: flex; flex-direction: column; align-items: center; max-width: 380px; margin: 0 auto; }
.h-layer, .h-hub {
  width: 100%; display: flex; flex-direction: column; align-items: center; text-align: center; gap: 0.4rem;
  border-radius: var(--radius-lg); padding: 1.3rem 1.5rem;
}
.h-layer {
