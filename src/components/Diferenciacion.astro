---
---

<section class="diferencia">
  <div class="container">

    <div class="dif-header reveal">
      <span class="eyebrow">Por qué Connect24</span>
      <h2>No es digitalización.<br><em>Es eliminación.</em></h2>
      <p class="section-desc">La diferencia entre tener una herramienta mejor y no tener que hacer la tarea.</p>
    </div>

    <div class="dif-grid reveal reveal-delay-1">

      <!-- Columna mala -->
      <div class="dif-col dif-col--bad">
        <div class="dif-col-header">
          <span class="dif-col-tag dif-col-tag--bad">GMAO / Software de registros</span>
        </div>
        <div class="dif-item dif-reveal" style="--i:0">
          <span class="dif-icon dif-icon--bad">✗</span>
          <span>Ayudan a gestionar mejor — sigues necesitando a alguien que gestione</span>
        </div>
        <div class="dif-item dif-reveal" style="--i:1">
          <span class="dif-icon dif-icon--bad">✗</span>
          <span>Eliminan el papel — sigues necesitando a alguien que rellene</span>
        </div>
        <div class="dif-item dif-reveal" style="--i:2">
          <span class="dif-icon dif-icon--bad">✗</span>
          <span>Dependen de que alguien recuerde hacerlo</span>
        </div>
        <div class="dif-item dif-reveal" style="--i:3">
          <span class="dif-icon dif-icon--bad">✗</span>
          <span>Te avisan cuando ya hay un problema</span>
        </div>
      </div>

      <!-- Divisor -->
      <div class="dif-divider">
        <div class="dif-divider-line"></div>
        <span class="dif-divider-vs">vs</span>
        <div class="dif-divider-line"></div>
      </div>

      <!-- Columna buena -->
      <div class="dif-col dif-col--good">
        <div class="dif-col-header">
          <span class="dif-col-tag dif-col-tag--good">Connect24</span>
        </div>
        <div class="dif-item dif-item--good dif-reveal" style="--i:0">
          <span class="dif-icon dif-icon--good">✓</span>
          <span>El dato entra, se interpreta, y la tarea se hace — sin intervención humana</span>
        </div>
        <div class="dif-item dif-item--good dif-reveal" style="--i:1">
          <span class="dif-icon dif-icon--good">✓</span>
          <span>El ciclo completo ocurre solo: captura → inteligencia → acción</span>
        </div>
        <div class="dif-item dif-item--good dif-reveal" style="--i:2">
          <span class="dif-icon dif-icon--good">✓</span>
          <span>Funciona 24/7 sin que nadie tenga que recordarlo</span>
        </div>
        <div class="dif-item dif-item--good dif-reveal" style="--i:3">
          <span class="dif-icon dif-icon--good">✓</span>
          <span>Detecta y actúa antes de que sea un problema</span>
        </div>
      </div>

    </div>
  </div>
</section>

<style>
  .diferencia {
    padding: 7rem 2rem;
    background: var(--c24-bg);
  }

  .dif-header {
    max-width: 620px;
    margin-bottom: 4rem;
  }
  .dif-header h2 { margin-bottom: 1rem; }
  .dif-header h2 em {
    font-style: italic;
    color: var(--c24-teal);
  }

  /* ── Grid ── */
  .dif-grid {
    display: grid;
    grid-template-columns: 1fr auto 1fr;
    gap: 2rem;
    align-items: start;
  }

  /* ── Columnas ── */
  .dif-col {
    background: var(--c24-surface);
    border: 1px solid var(--c24-border);
    border-radius: var(--radius-lg);
    padding: 2rem;
  }
  .dif-col--good {
    border-color: rgba(0,180,160,0.3);
    box-shadow: 0 4px 32px rgba(0,180,160,0.06);
  }

  .dif-col-header { margin-bottom: 1.75rem; }

  .dif-col-tag {
    display: inline-block;
    font-size: 0.78rem; font-weight: 700;
    letter-spacing: 0.06em;
    padding: 0.35rem 0.9rem;
    border-radius: var(--radius-pill);
  }
  .dif-col-tag--bad {
    background: rgba(13,45,68,0.06);
    color: var(--c24-text-muted);
  }
  :global([data-theme="dark"]) .dif-col-tag--bad {
    background: rgba(255,255,255,0.06);
  }
  .dif-col-tag--good {
    background: rgba(0,180,160,0.12);
    color: var(--c24-teal);
  }

  /* ── Items ── */
  .dif-item {
    display: flex;
    align-items: flex-start;
    gap: 0.75rem;
    padding: 0.85rem 0.5rem;
    border-bottom: 1px solid var(--c24-border);
    font-size: 0.9rem;
    line-height: 1.5;
    border-radius: var(--radius-sm);
    transition: background 0.2s, box-shadow 0.2s;
  }
  .dif-item:last-child { border-bottom: none; }

  .dif-col--bad .dif-item { color: var(--c24-text-muted); }
  .dif-col--good .dif-item { color: var(--c24-text); }

  /* Hover solo en los buenos */
  .dif-item--good:hover {
    background: rgba(0,180,160,0.05);
    box-shadow: inset 3px 0 0 var(--c24-teal);
    padding-left: 0.85rem;
  }

  .dif-icon {
    font-size: 0.85rem;
    flex-shrink: 0;
    margin-top: 0.1rem;
    font-weight: 700;
  }
  .dif-icon--bad  { color: rgba(200,60,60,0.6); }
  .dif-icon--good { color: var(--c24-teal); }

  /* ── Entrada escalonada ── */
  .dif-reveal {
    opacity: 0;
    transform: translateY(12px);
    transition:
      opacity 0.45s var(--ease-out),
      transform 0.45s var(--ease-out),
      background 0.2s,
      box-shadow 0.2s,
      padding-left 0.2s;
    transition-delay: calc(var(--i) * 0.1s);
  }
  .dif-reveal.visible {
    opacity: 1;
    transform: translateY(0);
  }

  /* ── Divisor ── */
  .dif-divider {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding-top: 4rem;
  }
  .dif-divider-line {
    width: 1px;
    flex: 1;
    background: var(--c24-border);
  }
  .dif-divider-vs {
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: var(--c24-text-muted);
    opacity: 0.5;
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .dif-grid {
      grid-template-columns: 1fr;
      gap: 1rem;
    }
    .dif-divider {
      flex-direction: row;
      padding-top: 0;
    }
    .dif-divider-line { flex: 1; height: 1px; width: auto; }
    .diferencia { padding: 5rem 1.5rem; }
  }
</style>

<script>
  const items = document.querySelectorAll('.dif-reveal');
  const observer = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        observer.unobserve(entry.target);
      }
    });
  }, { threshold: 0.1 });
  items.forEach(el => observer.observe(el));

  // Scroll reveal general
  const reveals = document.querySelectorAll('.reveal');
  const revealObserver = new IntersectionObserver((entries) => {
    entries.forEach(entry => {
      if (entry.isIntersecting) {
        entry.target.classList.add('visible');
        revealObserver.unobserve(entry.target);
      }
    });
  }, { threshold: 0.08 });
  reveals.forEach(el => revealObserver.observe(el));
</script>