}
.c360-search :global(svg) { width: 0.75rem; height: 0.75rem; }
.c360-filter-pill {
  font-size: 0.68rem; font-weight: 600; color: var(--c24-text-muted);
  padding: 0.3rem 0.7rem; border-radius: var(--radius-pill); border: 1px solid var(--c24-border);
  white-space: nowrap;
}

.c360-table-scroll { overflow-x: auto; }
.c360-table { width: 100%; border-collapse: collapse; min-width: 480px; }
.c360-table th {
