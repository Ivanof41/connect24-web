<style>
/* ═══════════════════════════════════════════════
   HERO
═══════════════════════════════════════════════ */
.c360-hero {
  padding: 9rem 2rem 4rem;
  background: #f5f8fc;
  position: relative; overflow: hidden;
}
:global([data-theme="dark"]) .c360-hero {
  background: linear-gradient(135deg, #080F18 0%, #0a1520 55%, #080F18 100%);
}
.c360-hero::before {
  content: '';
  position: absolute; inset: 0; pointer-events: none;
  background: radial-gradient(ellipse 55% 80% at 50% 0%, rgba(106,181,171,0.14) 0%, transparent 70%);
}
.c360-hero-inner { position: relative; z-index: 1; text-align: center; }
.c360-eyebrow-badge {
  display: inline-flex; align-items: center;
  background: var(--c24-teal-light); color: var(--c24-teal-dark);
  font-size: 0.72rem; font-weight: 700;
  letter-spacing: 0.12em; text-transform: uppercase;
  padding: 0.35rem 0.9rem; border-radius: var(--radius-pill);
  margin-bottom: 1.25rem;
}
:global([data-theme="dark"]) .c360-eyebrow-badge { background: rgba(106,181,171,0.14); }
.c360-hero-title {
  font-family: var(--font-display);
  font-size: clamp(2.6rem, 5vw, 4rem);
  font-weight: 700; letter-spacing: -0.02em;
  color: var(--c24-navy); margin-bottom: 0.75rem;
}
:global([data-theme="dark"]) .c360-hero-title { color: #fff; }
.c360-hero-sub {
  font-size: 1.1rem; color: var(--c24-text-muted);
  font-weight: 300; max-width: 480px; margin: 0 auto;
}

/* ═══════════════════════════════════════════════
   SHARED SECTION LAYOUT
═══════════════════════════════════════════════ */
.c360-section { padding: 6rem 2rem; }
.c360-bg-a { background: #ffffff; }
:global([data-theme="dark"]) .c360-bg-a { background: var(--c24-bg); }
.c360-bg-b { background: #f5f8fc; }
:global([data-theme="dark"]) .c360-bg-b { background: var(--c24-surface); }

.c360-grid {
  display: grid; grid-template-columns: 1fr 1fr;
  gap: 6.5rem; align-items: center;
}
.c360-num-row { display: flex; align-items: center; gap: 0.75rem; margin-bottom: 0.75rem; }
.c360-num {
  font-family: var(--font-body); font-weight: 800; font-size: 0.85rem;
  width: 34px; height: 34px; flex-shrink: 0;
  border-radius: 50%; display: flex; align-items: center; justify-content: center;
  background: var(--c24-navy); color: var(--c24-teal);
  border: 2px solid var(--c24-teal);
}
:global([data-theme="dark"]) .c360-num { background: rgba(106,181,171,0.12); }

/* Title/desc list with icon + title + description */
.c360-list { list-style: none; display: flex; flex-direction: column; gap: 1.1rem; margin-top: 0.5rem; }
.c360-list li { display: flex; align-items: flex-start; gap: 0.85rem; }
.c360-list-icon {
  flex-shrink: 0; width: 2.1rem; height: 2.1rem;
  border-radius: 10px; background: var(--c24-teal-light);
  display: flex; align-items: center; justify-content: center;
  color: var(--c24-teal-dark);
}
:global([data-theme="dark"]) .c360-list-icon { background: rgba(106,181,171,0.14); }
.c360-list-icon :global(svg) { width: 1.1rem; height: 1.1rem; }
.c360-list-text { font-size: 0.9rem; color: var(--c24-text-muted); line-height: 1.6; font-weight: 300; }
.c360-list-text strong { color: var(--c24-text); font-weight: 600; }

/* Simple checkmark list (section 4) */
.c360-checklist { list-style: none; display: flex; flex-direction: column; gap: 0.85rem; margin-top: 0.5rem; }
.c360-checklist li { display: flex; align-items: flex-start; gap: 0.6rem; font-size: 0.95rem; color: var(--c24-text); line-height: 1.4; }
.c360-check {
  flex-shrink: 0; width: 1.25rem; height: 1.25rem;
  background: var(--c24-teal); color: white; border-radius: 50%;
  display: flex; align-items: center; justify-content: center;
  font-size: 0.6rem; font-weight: 800; margin-top: 0.1rem;
}

/* ═══════════════════════════════════════════════
   01 · RADIAL DIAGRAM
═══════════════════════════════════════════════ */
.c360-radial {
  position: relative; width: 100%; aspect-ratio: 1/1; max-width: 460px; margin: 0 auto;
}
.c360-radial-conn {
  position: absolute; inset: 0; width: 100%; height: 100%;
  color: var(--c24-teal); opacity: 0.4; overflow: visible;
}
.c360-rl { animation: c360Flow 2.6s linear infinite; }
.c360-rl0 { animation-delay: 0s; } .c360-rl1 { animation-delay: 0.2s; }
.c360-rl2 { animation-delay: 0.4s; } .c360-rl3 { animation-delay: 0.6s; }
.c360-rl4 { animation-delay: 0.8s; } .c360-rl5 { animation-delay: 1s; }
.c360-rl6 { animation-delay: 1.2s; }
@keyframes c360Flow { from { stroke-dashoffset: 8.8; } to { stroke-dashoffset: 0; } }

.c360-radial-center {
  position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%);
  width: 34%; aspect-ratio: 1/1; border-radius: 50%;
  background: linear-gradient(150deg, var(--c24-teal) 0%, var(--c24-teal-dark) 100%);
  display: flex; flex-direction: column; align-items: center; justify-content: center;
  text-align: center; gap: 2px; z-index: 2; padding: 0.5rem;
  box-shadow: 0 8px 32px rgba(106,181,171,0.35), 0 0 0 6px rgba(106,181,171,0.12);
  animation: c360Pulse 4s ease-in-out infinite;
}
@keyframes c360Pulse {
  0%, 100% { box-shadow: 0 8px 32px rgba(106,181,171,0.35), 0 0 0 6px rgba(106,181,171,0.12); }
  50%      { box-shadow: 0 8px 40px rgba(106,181,171,0.5), 0 0 0 10px rgba(106,181,171,0.08); }
}
.c360-center-name { font-family: var(--font-body); font-weight: 800; font-size: clamp(0.85rem, 2vw, 1.1rem); color: white; letter-spacing: -0.01em; }
.c360-center-sub { font-size: clamp(0.5rem, 1vw, 0.6rem); font-weight: 600; letter-spacing: 0.08em; text-transform: uppercase; color: rgba(255,255,255,0.85); }

.c360-node {
  /* Only the icon (2.4rem tall, first child) is centered on the anchor point,
     so the connector line ends at the icon and never crosses the label below it. */
  position: absolute; transform: translate(-50%, -1.2rem);
  display: flex; flex-direction: column; align-items: center; gap: 0.35rem;
  z-index: 1; width: 92px; text-align: center;
}
.c360-node-icon {
  width: 2.4rem; height: 2.4rem; border-radius: 50%;
  background: var(--c24-surface); border: 1px solid var(--c24-border);
  display: flex; align-items: center; justify-content: center;
  color: var(--c24-teal-dark); box-shadow: var(--shadow-sm);
}
.c360-node-icon :global(svg) { width: 1.15rem; height: 1.15rem; }
.c360-node-label { font-size: 0.66rem; font-weight: 600; color: var(--c24-text-muted); line-height: 1.2; }

/* ═══════════════════════════════════════════════
   02 · PROTOCOL GRID + TABLE CARD
═══════════════════════════════════════════════ */
.c360-protocols { display: grid; grid-template-columns: repeat(5, 1fr); gap: 0.6rem; margin-bottom: 1.25rem; }
.c360-proto {
  display: flex; flex-direction: column; align-items: center; gap: 0.45rem;
  padding: 0.85rem 0.4rem; border-radius: var(--radius-sm);
  background: var(--c24-surface); border: 1px solid var(--c24-border);
  transition: transform 0.2s var(--ease-out), box-shadow 0.2s;
}
.c360-proto:hover { transform: translateY(-3px); box-shadow: var(--shadow-sm); }
.c360-proto-icon { width: 1.7rem; height: 1.7rem; display: flex; align-items: center; justify-content: center; color: var(--c24-teal-dark); }
.c360-proto-icon img { width: 100%; height: 100%; object-fit: contain; }
.c360-proto-icon :global(svg) { width: 100%; height: 100%; }
.c360-proto span { font-size: 0.62rem; font-weight: 600; color: var(--c24-text-muted); text-align: center; line-height: 1.2; }

.c360-note {
  display: flex; align-items: flex-start; gap: 0.6rem;
  font-size: 0.85rem; color: var(--c24-text); font-weight: 500;
  padding: 0.85rem 1rem; border-radius: var(--radius-sm);
  background: var(--c24-teal-light); border: 1px solid rgba(106,181,171,0.25);
}
:global([data-theme="dark"]) .c360-note { background: rgba(106,181,171,0.1); }
.c360-note-icon { flex-shrink: 0; width: 1.1rem; height: 1.1rem; color: var(--c24-teal-dark); margin-top: 0.1rem; }
.c360-note-icon :global(svg) { width: 100%; height: 100%; }

/* Card shell reused by table + summary */
.c360-card {
  background: white; border: 1px solid var(--c24-border); border-radius: var(--radius-lg);
  box-shadow: var(--shadow-md); padding: 1.25rem 1.4rem; margin-bottom: 1rem;
}
:global([data-theme="dark"]) .c360-card { background: var(--c24-surface); }
.c360-table-head { display: flex; align-items: center; justify-content: space-between; gap: 0.75rem; margin-bottom: 1rem; flex-wrap: wrap; }
.c360-card-title { display: flex; align-items: center; gap: 0.5rem; font-size: 0.85rem; font-weight: 700; color: var(--c24-text); }
.c360-card-title :global(svg) { width: 1rem; height: 1rem; color: var(--c24-teal); }
.c360-table-controls { display: flex; align-items: center; gap: 0.5rem; }
.c360-search {
  display: flex; align-items: center; gap: 0.35rem;
