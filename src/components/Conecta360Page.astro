.c360-status-ok { color: #059669; font-weight: 700; font-size: 0.65rem; letter-spacing: 0.04em; }

.c360-stats-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.6rem; }
.c360-stat {
  background: white; border: 1px solid var(--c24-border); border-radius: var(--radius-sm);
  padding: 0.75rem 0.7rem; display: flex; flex-direction: column; gap: 0.15rem;
}
:global([data-theme="dark"]) .c360-stat { background: var(--c24-surface); }
.c360-stat-label { font-size: 0.6rem; font-weight: 600; color: var(--c24-text-muted); text-transform: uppercase; letter-spacing: 0.04em; }
.c360-stat-val { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.15rem; font-weight: 800; color: var(--c24-navy); }
:global([data-theme="dark"]) .c360-stat-val { color: var(--c24-text); }
.c360-stat-delta { font-size: 0.6rem; font-weight: 600; color: #059669; }

/* ═══════════════════════════════════════════════
   03 · SUMMARY DASHBOARD
═══════════════════════════════════════════════ */
.c360-summary-stats { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.6rem; margin-bottom: 1.1rem; }
.c360-mini-stat {
  display: flex; flex-direction: column; gap: 0.2rem;
  background: var(--c24-surface); border-radius: var(--radius-sm); padding: 0.65rem 0.6rem;
}
:global([data-theme="dark"]) .c360-mini-stat { background: rgba(255,255,255,0.03); }
.c360-mini-stat span { font-size: 0.58rem; font-weight: 600; color: var(--c24-text-muted); text-transform: uppercase; letter-spacing: 0.03em; }
.c360-mini-stat strong { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1.05rem; font-weight: 800; color: var(--c24-navy); }
:global([data-theme="dark"]) .c360-mini-stat strong { color: var(--c24-text); }
.c360-mini-stat--alert strong { color: #dc2626; }
.c360-mini-stat--alert em { font-style: normal; font-size: 0.58rem; font-weight: 700; color: #dc2626; }

.c360-summary-charts { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; margin-bottom: 1.1rem; }
.c360-chart-box { background: var(--c24-surface); border-radius: var(--radius-sm); padding: 0.75rem 0.85rem; display: flex; flex-direction: column; }
:global([data-theme="dark"]) .c360-chart-box { background: rgba(255,255,255,0.03); }
.c360-chart-label { font-size: 0.6rem; font-weight: 600; color: var(--c24-text-muted); text-transform: uppercase; letter-spacing: 0.03em; margin-bottom: 0.2rem; }
.c360-chart-val { font-family: 'Plus Jakarta Sans', sans-serif; font-size: 1rem; font-weight: 800; color: var(--c24-navy); margin-bottom: 0.5rem; }
:global([data-theme="dark"]) .c360-chart-val { color: var(--c24-text); }
.c360-chart-val small { font-size: 0.65rem; font-weight: 500; color: var(--c24-text-muted); }
.c360-bars { display: flex; align-items: flex-end; gap: 3px; height: 34px; }
.c360-bar { flex: 1; background: var(--c24-teal); border-radius: 2px 2px 0 0; opacity: 0.75; }
.c360-spark { width: 100%; height: 34px; }

.c360-summary-bottom { display: grid; grid-template-columns: 1fr 1fr; gap: 0.75rem; }
.c360-donut-box, .c360-events-box { background: var(--c24-surface); border-radius: var(--radius-sm); padding: 0.75rem 0.85rem; }
:global([data-theme="dark"]) .c360-donut-box, :global([data-theme="dark"]) .c360-events-box { background: rgba(255,255,255,0.03); }
.c360-donut-wrap { display: flex; align-items: center; gap: 0.85rem; }
.c360-donut {
  flex-shrink: 0; width: 3.6rem; height: 3.6rem; border-radius: 50%;
  background: conic-gradient(#ef4444 0deg 36deg, #f59e0b 36deg 108deg, var(--c24-teal) 108deg 144deg, #94a3b8 144deg 360deg);
  position: relative;
}
.c360-donut::after {
  content: ''; position: absolute; inset: 22%; border-radius: 50%; background: var(--c24-surface);
}
:global([data-theme="dark"]) .c360-donut::after { background: #101f30; }
.c360-donut-legend { list-style: none; display: flex; flex-direction: column; gap: 0.3rem; }
