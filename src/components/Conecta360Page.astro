---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Footer from './Footer.astro';
import type { Translations } from '../i18n/es';

interface Props {
  t: Translations;
  lang: string;
}
const { t, lang } = Astro.props;
const tc = t.conecta360;

const icons: Record<string, string> = {
  monitor: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="3" width="20" height="14" rx="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/></svg>`,
  cpu: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="6" y="6" width="12" height="12" rx="1"/><path d="M9 1v4M15 1v4M9 19v4M15 19v4M1 9h4M1 15h4M19 9h4M19 15h4"/></svg>`,
  activity: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"/></svg>`,
  cloud: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h.79a4.5 4.5 0 1 1 0 9z"/></svg>`,
  external: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>`,
  wifi: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12.55a11 11 0 0 1 14.08 0"/><path d="M1.42 9a16 16 0 0 1 21.16 0"/><path d="M8.53 16.11a6 6 0 0 1 6.95 0"/><line x1="12" y1="20" x2="12.01" y2="20"/></svg>`,
  radio: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M4.9 19.1C1 15.2 1 8.8 4.9 4.9"/><path d="M7.8 16.2c-2.3-2.3-2.3-6.1 0-8.5"/><circle cx="12" cy="12" r="2"/><path d="M16.2 7.8c2.3 2.3 2.3 6.1 0 8.5"/><path d="M19.1 4.9C23 8.8 23 15.2 19.1 19.1"/></svg>`,
  target: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>`,
  layers: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="12 2 2 7 12 12 22 7 12 2"/><polyline points="2 17 12 22 22 17"/><polyline points="2 12 12 17 22 12"/></svg>`,
  alert: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M10.29 3.86L1.82 18a2 2 0 0 0 1.71 3h16.94a2 2 0 0 0 1.71-3L13.71 3.86a2 2 0 0 0-3.42 0z"/><line x1="12" y1="9" x2="12" y2="13"/><line x1="12" y1="17" x2="12.01" y2="17"/></svg>`,
  clock: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>`,
  trending: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="23 6 13.5 15.5 8.5 10.5 1 18"/><polyline points="17 6 23 6 23 12"/></svg>`,
  filetext: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/><line x1="16" y1="13" x2="8" y2="13"/><line x1="16" y1="17" x2="8" y2="17"/></svg>`,
  search: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>`,
  grid: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="3" width="7" height="7"/><rect x="14" y="3" width="7" height="7"/><rect x="14" y="14" width="7" height="7"/><rect x="3" y="14" width="7" height="7"/></svg>`,
  mqtt: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="6" r="2"/><circle cx="19" cy="6" r="2"/><circle cx="5" cy="18" r="2"/><circle cx="19" cy="18" r="2"/><path d="M7 6h10M7 6L5 18M19 6l-2 12"/></svg>`,
  plug: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M9 2v4M15 2v4"/><path d="M6 8h12v4a6 6 0 0 1-12 0V8z"/><path d="M12 18v4"/></svg>`,
  code: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/></svg>`,
  database: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><ellipse cx="12" cy="5" rx="9" ry="3"/><path d="M3 5v14a9 3 0 0 0 18 0V5"/><path d="M3 12a9 3 0 0 0 18 0"/></svg>`,
  file: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>`,
  more: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="5" cy="12" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="19" cy="12" r="1.5"/></svg>`,
  user: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>`,
  home: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"/><polyline points="9 22 9 12 15 12 15 22"/></svg>`,
  bell: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8a6 6 0 0 0-12 0c0 7-3 9-3 9h18s-3-2-3-9"/><path d="M13.73 21a2 2 0 0 1-3.46 0"/></svg>`,
  wrench: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M14.7 6.3a1 1 0 0 0 0 1.4l1.6 1.6a1 1 0 0 0 1.4 0l3.77-3.77a6 6 0 0 1-7.94 7.94l-6.91 6.91a2.12 2.12 0 0 1-3-3l6.91-6.91a6 6 0 0 1 7.94-7.94l-3.76 3.76z"/></svg>`,
  settings: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="3"/><path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/></svg>`,
  shieldcheck: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/><polyline points="9 12 11 14 15 10"/></svg>`,
  zap: `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/></svg>`,
};

// Radius (in the 0-100 viewBox units) of each node icon, used to stop the
// connector line at the icon's near edge instead of its center — otherwise,
// for nodes above the hub, the line would cross through the label beneath the icon.
const ICON_R = 9;
const rawNodes = [
  { label: tc.s1_node1, x: 50,   y: 8,    icon: 'monitor' },
  { label: tc.s1_node2, x: 82.8, y: 23.8, icon: 'cpu' },
  { label: tc.s1_node3, x: 91,   y: 59.4, icon: 'activity' },
  { label: tc.s1_node4, x: 68.2, y: 87.8, icon: 'cloud' },
  { label: tc.s1_node5, x: 31.8, y: 87.8, icon: 'external' },
  { label: tc.s1_node6, x: 9,    y: 59.4, icon: 'wifi' },
  { label: tc.s1_node7, x: 17.2, y: 23.8, icon: 'radio' },
];
const nodes = rawNodes.map(n => {
  const dx = n.x - 50, dy = n.y - 50;
  const dist = Math.sqrt(dx * dx + dy * dy);
  const lineX = n.x - (dx / dist) * ICON_R;
  const lineY = n.y - (dy / dist) * ICON_R;
  return { ...n, lineX, lineY };
});

const s1items = [
  { title: tc.s1_item1_title, desc: tc.s1_item1_desc, icon: 'target' },
  { title: tc.s1_item2_title, desc: tc.s1_item2_desc, icon: 'layers' },
  { title: tc.s1_item3_title, desc: tc.s1_item3_desc, icon: 'alert' },
];

const s3items = [
  { title: tc.s3_item1_title, desc: tc.s3_item1_desc, icon: 'clock' },
  { title: tc.s3_item2_title, desc: tc.s3_item2_desc, icon: 'trending' },
  { title: tc.s3_item3_title, desc: tc.s3_item3_desc, icon: 'alert' },
  { title: tc.s3_item4_title, desc: tc.s3_item4_desc, icon: 'filetext' },
];

const s4items = [tc.s4_item1, tc.s4_item2, tc.s4_item3, tc.s4_item4];

const protocols = [
  { label: tc.s2_p1,  logo: '/logos/knx.svg' },
  { label: tc.s2_p2,  logo: '/logos/modbus.svg' },
  { label: tc.s2_p3,  logo: '/logos/bacnet.svg' },
  { label: tc.s2_p4,  icon: 'mqtt' },
  { label: tc.s2_p5,  logo: '/logos/lorawan.svg' },
  { label: tc.s2_p6,  icon: 'plug' },
  { label: tc.s2_p7,  icon: 'code' },
  { label: tc.s2_p8,  icon: 'database' },
  { label: tc.s2_p9,  icon: 'file' },
  { label: tc.s2_p10, icon: 'more' },
];

const dataRows = [
  { device: tc.s2_row1_device, variable: tc.s2_row1_variable, value: tc.s2_row1_value, unit: tc.s2_row1_unit, updated: tc.s2_row1_updated },
  { device: tc.s2_row2_device, variable: tc.s2_row2_variable, value: tc.s2_row2_value, unit: tc.s2_row2_unit, updated: tc.s2_row2_updated },
  { device: tc.s2_row3_device, variable: tc.s2_row3_variable, value: tc.s2_row3_value, unit: tc.s2_row3_unit, updated: tc.s2_row3_updated },
  { device: tc.s2_row4_device, variable: tc.s2_row4_variable, value: tc.s2_row4_value, unit: tc.s2_row4_unit, updated: tc.s2_row4_updated },
  { device: tc.s2_row5_device, variable: tc.s2_row5_variable, value: tc.s2_row5_value, unit: tc.s2_row5_unit, updated: tc.s2_row5_updated },
];

const stats2 = [
  { label: tc.s2_stat1_label, val: tc.s2_stat1_val, delta: tc.s2_stat1_delta },
  { label: tc.s2_stat2_label, val: tc.s2_stat2_val, delta: tc.s2_stat2_delta },
  { label: tc.s2_stat3_label, val: tc.s2_stat3_val, delta: tc.s2_stat3_delta },
  { label: tc.s2_stat4_label, val: tc.s2_stat4_val, delta: tc.s2_stat4_delta },
];

const energyBars = [40, 55, 35, 70, 50, 65, 80, 45, 60, 75, 55, 90];

const roles = [
  { label: tc.role1, icon: 'user' },
  { label: tc.role2, icon: 'wrench' },
  { label: tc.role3, icon: 'settings' },
  { label: tc.role4, icon: 'shieldcheck' },
  { label: tc.role5, icon: 'zap' },
];
---
<Layout title={tc.page_title} description={tc.page_desc}>
  <Nav t={t.nav} lang={lang} />

  <!-- ═══════════════════════════════════════════════
       HERO
  ═══════════════════════════════════════════════ -->
  <section class="c360-hero">
    <div class="container c360-hero-inner reveal">
      <span class="c360-eyebrow-badge">{tc.hero_eyebrow}</span>
      <h1 class="c360-hero-title">{tc.hero_title}</h1>
      <p class="c360-hero-sub">{tc.hero_sub}</p>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       01 · VISIÓN 360°
  ═══════════════════════════════════════════════ -->
  <section class="c360-section c360-bg-a">
    <div class="container c360-grid">
      <div class="c360-text reveal">
        <div class="c360-num-row">
          <span class="c360-num">{tc.s1_num}</span>
          <span class="eyebrow" style="margin:0;">{tc.s1_eyebrow}</span>
        </div>
        <h2>{tc.s1_title1}<br/>{tc.s1_title2}</h2>
        <p class="section-desc">{tc.s1_desc}</p>

        <ul class="c360-list">
          {s1items.map(item => (
            <li>
              <span class="c360-list-icon" set:html={icons[item.icon]} />
              <span class="c360-list-text"><strong>{item.title}</strong><br/>{item.desc}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="c360-visual reveal reveal-delay-2">
        <div class="c360-radial">
          <svg class="c360-radial-conn" viewBox="0 0 100 100" preserveAspectRatio="none">
            {nodes.map((n, i) => (
              <path class={`c360-rl c360-rl${i}`} d={`M${n.lineX},${n.lineY} L50,50`} fill="none" stroke="currentColor" stroke-width="0.6" stroke-dasharray="2.2 2.2"/>
            ))}
          </svg>
          <div class="c360-radial-center">
            <span class="c360-center-name">{tc.s1_center_name}</span>
            <span class="c360-center-sub">{tc.s1_center_sub}</span>
          </div>
          {nodes.map((n, i) => (
            <div class="c360-node" style={`left:${n.x}%; top:${n.y}%; animation-delay:${(i * 0.35).toFixed(2)}s`}>
              <div class="c360-node-icon" set:html={icons[n.icon]} />
              <span class="c360-node-label">{n.label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       02 · DATOS SIN LÍMITES
  ═══════════════════════════════════════════════ -->
  <section class="c360-section c360-bg-b">
    <div class="container c360-grid">
      <div class="c360-text reveal">
        <div class="c360-num-row">
          <span class="c360-num">{tc.s2_num}</span>
          <span class="eyebrow" style="margin:0;">{tc.s2_eyebrow}</span>
        </div>
        <h2>{tc.s2_title1}<br/>{tc.s2_title2}</h2>
        <p class="section-desc" style="margin-bottom:1.5rem;">{tc.s2_desc}</p>

        <div class="c360-protocols">
          {protocols.map(p => (
            <div class="c360-proto">
              <div class="c360-proto-icon">
                {p.logo ? <img src={p.logo} alt={p.label} /> : <span set:html={icons[p.icon as string]} />}
              </div>
              <span>{p.label}</span>
            </div>
          ))}
        </div>

        <div class="c360-note">
          <span class="c360-note-icon" set:html={icons.target} />
          {tc.s2_note}
        </div>
      </div>

      <div class="c360-visual reveal reveal-delay-2">
        <div class="c360-card c360-table-card">
          <div class="c360-table-head">
            <span class="c360-card-title"><span set:html={icons.grid} />{tc.s2_table_title}</span>
            <div class="c360-table-controls">
              <span class="c360-search"><span set:html={icons.search} />{tc.s2_table_search}</span>
              <span class="c360-filter-pill">{tc.s2_table_filter}</span>
            </div>
          </div>
          <div class="c360-table-scroll">
            <table class="c360-table">
              <thead>
                <tr>
                  <th>{tc.s2_col_device}</th>
                  <th>{tc.s2_col_variable}</th>
                  <th>{tc.s2_col_value}</th>
                  <th>{tc.s2_col_unit}</th>
                  <th>{tc.s2_col_updated}</th>
                  <th>{tc.s2_col_status}</th>
                </tr>
              </thead>
              <tbody>
                {dataRows.map(r => (
                  <tr>
                    <td>{r.device}</td>
                    <td>{r.variable}</td>
                    <td>{r.value}</td>
                    <td>{r.unit}</td>
                    <td>{r.updated}</td>
                    <td><span class="c360-status-ok">● {tc.s2_status_ok}</span></td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>

        <div class="c360-stats-row">
          {stats2.map(s => (
            <div class="c360-stat">
              <span class="c360-stat-label">{s.label}</span>
              <span class="c360-stat-val">{s.val}</span>
              <span class="c360-stat-delta">{s.delta}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ═══════════════════════════════════════════════
       03 · INFORMACIÓN CENTRALIZADA
  ═══════════════════════════════════════════════ -->
  <section class="c360-section c360-bg-a">
    <div class="container c360-grid">
      <div class="c360-text reveal">
        <div class="c360-num-row">
          <span class="c360-num">{tc.s3_num}</span>
          <span class="eyebrow" style="margin:0;">{tc.s3_eyebrow}</span>
        </div>
        <h2>{tc.s3_title1}<br/>{tc.s3_title2}</h2>
        <p class="section-desc">{tc.s3_desc}</p>

        <ul class="c360-list">
          {s3items.map(item => (
            <li>
              <span class="c360-list-icon" set:html={icons[item.icon]} />
              <span class="c360-list-text"><strong>{item.title}</strong><br/>{item.desc}</span>
            </li>
          ))}
        </ul>
      </div>

      <div class="c360-visual reveal reveal-delay-2">
        <div class="c360-card c360-summary-card">
          <div class="c360-table-head">
            <span class="c360-card-title">{tc.s3_dash_title}</span>
            <div class="c360-table-controls">
              <span class="c360-filter-pill">{tc.s3_dash_today}</span>
              <span class="c360-filter-pill">{tc.s3_dash_allinst}</span>
            </div>
          </div>

          <div class="c360-summary-stats">
            <div class="c360-mini-stat">
              <span>{tc.s3_stat_installs_label}</span>
              <strong>{tc.s3_stat_installs_val}</strong>
            </div>
            <div class="c360-mini-stat">
              <span>{tc.s3_stat_devices_label}</span>
              <strong>{tc.s3_stat_devices_val}</strong>
            </div>
            <div class="c360-mini-stat">
              <span>{tc.s3_stat_points_label}</span>
              <strong>{tc.s3_stat_points_val}</strong>
            </div>
            <div class="c360-mini-stat c360-mini-stat--alert">
              <span>{tc.s3_stat_alarms_label}</span>
              <strong>{tc.s3_stat_alarms_val}</strong>
              <em>{tc.s3_stat_alarms_crit}</em>
            </div>
          </div>

          <div class="c360-summary-charts">
            <div class="c360-chart-box">
              <span class="c360-chart-label">{tc.s3_energy_label}</span>
              <span class="c360-chart-val">{tc.s3_energy_val} <small>{tc.s3_energy_unit}</small></span>
              <div class="c360-bars">
                {energyBars.map(h => <div class="c360-bar" style={`height:${h}%`}></div>)}
              </div>
            </div>
            <div class="c360-chart-box">
              <span class="c360-chart-label">{tc.s3_temp_label}</span>
              <span class="c360-chart-val">{tc.s3_temp_val} <small>{tc.s3_temp_unit}</small></span>
              <svg class="c360-spark" viewBox="0 0 100 30" preserveAspectRatio="none">
