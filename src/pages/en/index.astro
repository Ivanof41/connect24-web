---
import Layout from '../../layouts/Layout.astro';
import Nav from '../../components/Nav.astro';
import Hero from '../../components/Hero.astro';
import ProblemaYSolucion from '../../components/ProblemaYSolucion.astro';
import ComoFunciona from '../../components/ComoFunciona.astro';
import Calculadora from '../../components/Calculadora.astro';
import Diferenciacion from '../../components/Diferenciacion.astro';
import PruebaSocial from '../../components/PruebaSocial.astro';
import CtaFinal from '../../components/CtaFinal.astro';
import Modal from '../../components/Modal.astro';
import Footer from '../../components/Footer.astro';

import { getLang, useTranslations } from '../../i18n/index';

const lang = getLang(Astro.url);
const t    = useTranslations(lang);
---

<Layout title={`Connect24 — ${t.hero.slogan1}. ${t.hero.slogan2}.`}>
  <Nav t={t.nav} lang={lang} />
  <Hero t={t.hero} />
  <ProblemaYSolucion t={t.problema} />
  <ComoFunciona t={t.como} />
  <Calculadora t={t.calculadora} />
  <Diferenciacion t={t.diferencia} />
  <PruebaSocial t={t.social} />
  <CtaFinal t={t.cta} />
  <Modal t={t.modal} t_calc={t.calculadora} />
  <Footer t={t.footer} />
</Layout>